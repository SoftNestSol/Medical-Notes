{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.52,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule Crețu."
    },
    {
      "start": 1.64,
      "end": 2.44,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.56,
      "end": 4.84,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem astăzi?"
    },
    {
      "start": 4.96,
      "end": 6.1,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 6.22,
      "end": 7.74,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De cât timp?"
    },
    {
      "start": 7.86,
      "end": 9.38,
      "speaker": "SPEAKER_01",
      "text": "De vreo două săptămâni."
    },
    {
      "start": 9.5,
      "end": 14.82,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. Și a apărut după ceva anume, după un efort, după o mișcare?"
    },
    {
      "start": 14.94,
      "end": 17.98,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, m-am trezit dimineața și era."
    },
    {
      "start": 18.1,
      "end": 23.42,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Doare doar în zona gâtului sau se lasă și spre umăr, spre cap?"
    },
    {
      "start": 23.54,
      "end": 25.44,
      "speaker": "SPEAKER_01",
      "text": "Și spre umăr, pe dreapta."
    },
    {
      "start": 25.56,
      "end": 28.6,
      "speaker": "SPEAKER_00",
      "text": "Spre umărul drept. Amorțește ceva, vreun deget, mâna?"
    },
    {
      "start": 28.72,
      "end": 29.52,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 29.64,
      "end": 38.76,
      "speaker": "SPEAKER_00",
      "text": "Nu. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, cât de tare e durerea?"
    },
    {
      "start": 38.88,
      "end": 39.68,
      "speaker": "SPEAKER_01",
      "text": "Un 5."
    },
    {
      "start": 39.8,
      "end": 43.98,
      "speaker": "SPEAKER_00",
      "text": "Un 5. Doare mai tare când stați la birou, la calculator?"
    },
    {
      "start": 44.1,
      "end": 44.9,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 45.02,
      "end": 46.92,
      "speaker": "SPEAKER_00",
      "text": "Mult timp la birou zilnic?"
    },
    {
      "start": 47.04,
      "end": 48.18,
      "speaker": "SPEAKER_01",
      "text": "Cam mult, da."
    },
    {
      "start": 48.3,
      "end": 49.44,
      "speaker": "SPEAKER_00",
      "text": "Cam câte ore?"
    },
    {
      "start": 49.56,
      "end": 51.46,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, vreo opt ore."
    },
    {
      "start": 51.58,
      "end": 58.42,
      "speaker": "SPEAKER_00",
      "text": "Opt ore la birou. Și în ce poziție stați de obicei, cu capul în față, aplecat spre ecran?"
    },
    {
      "start": 58.54,
      "end": 59.34,
      "speaker": "SPEAKER_01",
      "text": "Probabil, da."
    },
    {
      "start": 59.46,
      "end": 61.74,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Doare și când întoarceți capul?"
    },
    {
      "start": 61.86,
      "end": 64.14,
      "speaker": "SPEAKER_01",
      "text": "Da, pe dreapta nu prea pot."
    },
    {
      "start": 64.26,
      "end": 68.44,
      "speaker": "SPEAKER_00",
      "text": "Nu puteți roti spre dreapta. Și dacă dați capul pe spate?"
    },
    {
      "start": 68.56,
      "end": 69.7,
      "speaker": "SPEAKER_01",
      "text": "Da, și atunci."
    },
    {
      "start": 69.82,
      "end": 74.38,
      "speaker": "SPEAKER_00",
      "text": "Și atunci. Bun. Alte afecțiuni, cum ar fi tensiune, diabet, osteoporoză, epilepsie?"
    },
    {
      "start": 74.5,
      "end": 75.3,
      "speaker": "SPEAKER_01",
      "text": "Tensiune am."
    },
    {
      "start": 75.42,
      "end": 77.32,
      "speaker": "SPEAKER_00",
      "text": "Tensiune. Luați ceva pentru ea?"
    },
    {
      "start": 77.44,
      "end": 78.24,
      "speaker": "SPEAKER_01",
      "text": "Da, Enalapril."
    },
    {
      "start": 78.36,
      "end": 79.16,
      "speaker": "SPEAKER_00",
      "text": "Ce doză?"
    },
    {
      "start": 79.28,
      "end": 80.08,
      "speaker": "SPEAKER_01",
      "text": "10 miligrame."
    },
    {
      "start": 80.2,
      "end": 82.48,
      "speaker": "SPEAKER_00",
      "text": "10 miligrame, Enalapril. Altceva mai luați?"
    },
    {
      "start": 82.6,
      "end": 83.4,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 83.52,
      "end": 84.66,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale, fracturi?"
    },
    {
      "start": 84.78,
      "end": 85.58,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 85.7,
      "end": 87.6,
      "speaker": "SPEAKER_00",
      "text": "Boli cu transmitere prin sânge?"
    },
    {
      "start": 87.72,
      "end": 88.52,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 88.64,
      "end": 89.44,
      "speaker": "SPEAKER_00",
      "text": "Implanturi, proteze?"
    },
    {
      "start": 89.56,
      "end": 90.36,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 90.48,
      "end": 94.66,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să fac câteva verificări. Stați puțin drept pentru mine."
    },
    {
      "start": 94.78,
      "end": 95.58,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 95.7,
      "end": 103.68,
      "speaker": "SPEAKER_00",
      "text": "Observ că umărul drept e puțin mai sus față de cel stâng. Acum apăs ușor pe musculatura gâtului pe dreapta. Doare?"
    },
    {
      "start": 103.8,
      "end": 104.6,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 104.72,
      "end": 105.86,
      "speaker": "SPEAKER_00",
      "text": "Și pe stânga?"
    },
    {
      "start": 105.98,
      "end": 106.78,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 106.9,
      "end": 110.7,
      "speaker": "SPEAKER_00",
      "text": "Mai puțin pe stânga. Rotiți puțin capul spre dreapta, încet."
    },
    {
      "start": 110.82,
      "end": 113.1,
      "speaker": "SPEAKER_01",
      "text": "Au, da, nu pot mai mult."
    },
    {
      "start": 113.22,
      "end": 114.74,
      "speaker": "SPEAKER_00",
      "text": "Opriți acolo. Spre stânga?"
    },
    {
      "start": 114.86,
      "end": 116.0,
      "speaker": "SPEAKER_01",
      "text": "Merge mai bine."
    },
    {
      "start": 116.12,
      "end": 137.4,
      "speaker": "SPEAKER_00",
      "text": "Merge mai bine spre stânga. Deci avem o limitare a rotației spre dreapta și o tensionare a musculaturii cervicale, în special pe dreapta. Pare a fi o contractură cervicală cu posibilă iritație la nivel C5-C6, dat fiind că se lasă și spre umărul drept. Vom lucra să reducem contractura musculară și să refacem mobilitatea cervicală."
    },
    {
      "start": 137.52,
      "end": 138.32,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 138.44,
      "end": 141.86,
      "speaker": "SPEAKER_00",
      "text": "Haideți pe masă, vă rog, cu fața în sus."
    }
  ]
}
