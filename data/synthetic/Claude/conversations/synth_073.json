{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua!"
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 3.74,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă venim astăzi?"
    },
    {
      "start": 3.86,
      "end": 5.0,
      "speaker": "SPEAKER_01",
      "text": "Mă doare umărul."
    },
    {
      "start": 5.12,
      "end": 7.02,
      "speaker": "SPEAKER_00",
      "text": "Care umăr, dreptul sau stângul?"
    },
    {
      "start": 7.14,
      "end": 7.94,
      "speaker": "SPEAKER_01",
      "text": "Dreptul."
    },
    {
      "start": 8.06,
      "end": 8.86,
      "speaker": "SPEAKER_00",
      "text": "De când?"
    },
    {
      "start": 8.98,
      "end": 10.12,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 10.24,
      "end": 14.8,
      "speaker": "SPEAKER_00",
      "text": "S-a întâmplat ceva, ai lovit, ai căzut, ai ridicat ceva greu?"
    },
    {
      "start": 14.92,
      "end": 17.2,
      "speaker": "SPEAKER_01",
      "text": "Am ridicat niște saci la serviciu."
    },
    {
      "start": 17.32,
      "end": 25.68,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, unde situezi durerea?"
    },
    {
      "start": 25.8,
      "end": 26.6,
      "speaker": "SPEAKER_01",
      "text": "Vreo 6."
    },
    {
      "start": 26.72,
      "end": 29.38,
      "speaker": "SPEAKER_00",
      "text": "Doare constant sau doar când miști brațul?"
    },
    {
      "start": 29.5,
      "end": 31.4,
      "speaker": "SPEAKER_01",
      "text": "Când îl ridic mai ales."
    },
    {
      "start": 31.52,
      "end": 36.84,
      "speaker": "SPEAKER_00",
      "text": "Ridici brațul în față, în lateral, în spate, care mișcare doare cel mai tare?"
    },
    {
      "start": 36.96,
      "end": 37.76,
      "speaker": "SPEAKER_01",
      "text": "În lateral."
    },
    {
      "start": 37.88,
      "end": 39.02,
      "speaker": "SPEAKER_00",
      "text": "Și în față?"
    },
    {
      "start": 39.14,
      "end": 39.94,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 40.06,
      "end": 44.62,
      "speaker": "SPEAKER_00",
      "text": "Durerea rămâne în umăr sau se lasă și pe braț în jos?"
    },
    {
      "start": 44.74,
      "end": 45.54,
      "speaker": "SPEAKER_01",
      "text": "Rămâne acolo."
    },
    {
      "start": 45.66,
      "end": 48.32,
      "speaker": "SPEAKER_00",
      "text": "Ok. Noaptea te trezești din cauza ei?"
    },
    {
      "start": 48.44,
      "end": 49.24,
      "speaker": "SPEAKER_01",
      "text": "Da, uneori."
    },
    {
      "start": 49.36,
      "end": 51.26,
      "speaker": "SPEAKER_00",
      "text": "Când stai pe partea dreaptă?"
    },
    {
      "start": 51.38,
      "end": 52.18,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 52.3,
      "end": 55.72,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Ai mai pățit asta vreodată, cu același umăr?"
    },
    {
      "start": 55.84,
      "end": 56.64,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 56.76,
      "end": 60.18,
      "speaker": "SPEAKER_00",
      "text": "Alte probleme de sănătate, tensiune, diabet, probleme cu oasele?"
    },
    {
      "start": 60.3,
      "end": 61.1,
      "speaker": "SPEAKER_01",
      "text": "Nu, nimic."
    },
    {
      "start": 61.22,
      "end": 62.74,
      "speaker": "SPEAKER_00",
      "text": "Iei vreun medicament acum?"
    },
    {
      "start": 62.86,
      "end": 64.76,
      "speaker": "SPEAKER_01",
      "text": "Nurofen, când nu mai pot."
    },
    {
      "start": 64.88,
      "end": 66.02,
      "speaker": "SPEAKER_00",
      "text": "Cât de des?"
    },
    {
      "start": 66.14,
      "end": 69.18,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, de două, trei ori pe săptămână."
    },
    {
      "start": 69.3,
      "end": 70.82,
      "speaker": "SPEAKER_00",
      "text": "Ok. Alergii la medicamente?"
    },
    {
      "start": 70.94,
      "end": 71.74,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 71.86,
      "end": 78.7,
      "speaker": "SPEAKER_00",
      "text": "Bun. Hai să facem câteva mișcări să văd cum stăm. Ridică brațul drept în lateral pentru mine, încet."
    },
    {
      "start": 78.82,
      "end": 79.96,
      "speaker": "SPEAKER_01",
      "text": "Până aici pot."
    },
    {
      "start": 80.08,
      "end": 80.88,
      "speaker": "SPEAKER_00",
      "text": "Doare acum?"
    },
    {
      "start": 81.0,
      "end": 81.8,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 81.92,
      "end": 86.86,
      "speaker": "SPEAKER_00",
      "text": "La aproximativ 80 de grade se oprește. Acum ridică și brațul stâng, comparat."
    },
    {
      "start": 86.98,
      "end": 88.12,
      "speaker": "SPEAKER_01",
      "text": "Ăsta merge normal."
    },
    {
      "start": 88.24,
      "end": 95.08,
      "speaker": "SPEAKER_00",
      "text": "Da, stângul merge complet. Acum pune mâna dreaptă la spate, ca și cum ai prinde ceva de jos."
    },
    {
      "start": 95.2,
      "end": 96.34,
      "speaker": "SPEAKER_01",
      "text": "Au, nu pot."
    },
    {
      "start": 96.46,
      "end": 99.88,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Și dacă apăs aici, pe capul humerusului, doare?"
    },
    {
      "start": 100.0,
      "end": 100.8,
      "speaker": "SPEAKER_01",
      "text": "Da, tare."
    },
    {
      "start": 100.92,
      "end": 115.36,
      "speaker": "SPEAKER_00",
      "text": "Mă gândesc că avem o inflamație la nivelul tendoanelor din umăr, zona de coafă a rotatorilor. Limitarea aceea de mișcare în abducție și durerea la apăsare sunt tipice. O să lucrăm să reducem inflamația și să recăpătăm mobilitatea."
    },
    {
      "start": 115.48,
      "end": 116.28,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 116.4,
      "end": 124.38,
      "speaker": "SPEAKER_00",
      "text": "Să știi că Nurofen-ul ajută pe moment, dar nu rezolvă cauza. O să vedem după primele două ședințe cum răspunde."
    },
    {
      "start": 124.5,
      "end": 125.3,
      "speaker": "SPEAKER_01",
      "text": "Bine."
    }
  ]
}
