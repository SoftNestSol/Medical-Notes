  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua."
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 1.84,
      "end": 4.5,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi, cu ce problemă veniți azi?"
    },
    {
      "start": 4.62,
      "end": 5.76,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 5.88,
      "end": 7.4,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De cât timp?"
    },
    {
      "start": 7.52,
      "end": 9.04,
      "speaker": "SPEAKER_01",
      "text": "De vreo două săptămâni."
    },
    {
      "start": 9.16,
      "end": 13.34,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. Și a apărut din senin sau după ceva anume?"
    },
    {
      "start": 13.46,
      "end": 15.74,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, poate de la birou."
    },
    {
      "start": 15.86,
      "end": 17.38,
      "speaker": "SPEAKER_00",
      "text": "Stați mult la calculator?"
    },
    {
      "start": 17.5,
      "end": 18.3,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 18.42,
      "end": 20.32,
      "speaker": "SPEAKER_00",
      "text": "Câte ore pe zi aproximativ?"
    },
    {
      "start": 20.44,
      "end": 21.96,
      "speaker": "SPEAKER_01",
      "text": "Vreo opt ore, nouă."
    },
    {
      "start": 22.08,
      "end": 25.5,
      "speaker": "SPEAKER_00",
      "text": "Ok. Doare doar gâtul sau se duce și undeva?"
    },
    {
      "start": 25.62,
      "end": 27.14,
      "speaker": "SPEAKER_01",
      "text": "Și în umărul ăsta."
    },
    {
      "start": 27.26,
      "end": 29.16,
      "speaker": "SPEAKER_00",
      "text": "Care umăr, stângul sau dreptul?"
    },
    {
      "start": 29.28,
      "end": 30.08,
      "speaker": "SPEAKER_01",
      "text": "Dreptul."
    },
    {
      "start": 30.2,
      "end": 35.14,
      "speaker": "SPEAKER_00",
      "text": "Deci cervical și umărul drept. Se lasă mai departe, pe braț, pe mână?"
    },
    {
      "start": 35.26,
      "end": 36.06,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 36.18,
      "end": 37.32,
      "speaker": "SPEAKER_00",
      "text": "Amorțeli la degete?"
    },
    {
      "start": 37.44,
      "end": 38.24,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 38.36,
      "end": 39.88,
      "speaker": "SPEAKER_00",
      "text": "Amețeli, dureri de cap?"
    },
    {
      "start": 40.0,
      "end": 41.9,
      "speaker": "SPEAKER_01",
      "text": "Câteodată mă doare capul, da."
    },
    {
      "start": 42.02,
      "end": 42.82,
      "speaker": "SPEAKER_00",
      "text": "Des?"
    },
    {
      "start": 42.94,
      "end": 43.74,
      "speaker": "SPEAKER_01",
      "text": "Nu, rar."
    },
    {
      "start": 43.86,
      "end": 52.98,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte tare, cât e durerea acum la gât?"
    },
    {
      "start": 53.1,
      "end": 53.9,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 54.02,
      "end": 55.54,
      "speaker": "SPEAKER_00",
      "text": "5. Și la umăr?"
    },
    {
      "start": 55.66,
      "end": 56.8,
      "speaker": "SPEAKER_01",
      "text": "Cam la fel."
    },
    {
      "start": 56.92,
      "end": 62.62,
      "speaker": "SPEAKER_00",
      "text": "Deci tot un 5. Doare mai mult când stați la birou sau când vă mișcați?"
    },
    {
      "start": 62.74,
      "end": 64.64,
      "speaker": "SPEAKER_01",
      "text": "Când stau jos mai mult."
    },
    {
      "start": 64.76,
      "end": 67.04,
      "speaker": "SPEAKER_00",
      "text": "Când vă ridicați se mai ameliorează?"
    },
    {
      "start": 67.16,
      "end": 68.3,
      "speaker": "SPEAKER_01",
      "text": "Un pic, da."
    },
    {
      "start": 68.42,
      "end": 70.7,
      "speaker": "SPEAKER_00",
      "text": "Noaptea vă deranjează, nu puteți dormi?"
    },
    {
      "start": 70.82,
      "end": 73.1,
      "speaker": "SPEAKER_01",
      "text": "Uneori nu găsesc o poziție bună."
    },
    {
      "start": 73.22,
      "end": 76.26,
      "speaker": "SPEAKER_00",
      "text": "Ok. Alte afecțiuni, tensiune, diabet, osteoporoză, ceva diagnosticat?"
    },
    {
      "start": 76.38,
      "end": 77.18,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 77.3,
      "end": 78.1,
      "speaker": "SPEAKER_00",
      "text": "Niciuna."
    },
    {
      "start": 78.22,
      "end": 79.02,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 79.14,
      "end": 79.94,
      "speaker": "SPEAKER_00",
      "text": "Operații, fracturi?"
    },
    {
      "start": 80.06,
      "end": 80.86,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 80.98,
      "end": 82.5,
      "speaker": "SPEAKER_00",
      "text": "Luați vreun medicament acum?"
    },
    {
      "start": 82.62,
      "end": 87.94,
      "speaker": "SPEAKER_01",
      "text": "Am luat un ibuprofen când m-a durut mai tare, dar nu iau constant."
    },
    {
      "start": 88.06,
      "end": 90.72,
      "speaker": "SPEAKER_00",
      "text": "Deci nu luați nimic în mod regulat."
    },
    {
      "start": 90.84,
      "end": 91.64,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 91.76,
      "end": 104.3,
      "speaker": "SPEAKER_00",
      "text": "Bun. Stați puțin, întoarceți-vă cu spatele la mine. Relaxați umerii. Văd că aveți capul dus puțin înainte și umărul drept e mai ridicat ca stângul. Întoarceți capul la dreapta pentru mine, încet."
    },
    {
      "start": 104.42,
      "end": 105.22,
      "speaker": "SPEAKER_01",
      "text": "Până aici."
    },
    {
      "start": 105.34,
      "end": 106.14,
      "speaker": "SPEAKER_00",
      "text": "Doare?"
    },
    {
      "start": 106.26,
      "end": 107.4,
      "speaker": "SPEAKER_01",
      "text": "Da, se trage."
    },
    {
      "start": 107.52,
      "end": 108.66,
      "speaker": "SPEAKER_00",
      "text": "Și la stânga?"
    },
    {
      "start": 108.78,
      "end": 109.92,
      "speaker": "SPEAKER_01",
      "text": "Merge mai bine."
    },
    {
      "start": 110.04,
      "end": 114.98,
      "speaker": "SPEAKER_00",
      "text": "Da, văd că rotația la dreapta e limitată. Aplecați capul spre umărul drept."
    },
    {
      "start": 115.1,
      "end": 115.9,
      "speaker": "SPEAKER_01",
      "text": "Au, da."
    },
    {
      "start": 116.02,
      "end": 120.2,
      "speaker": "SPEAKER_00",
      "text": "Ok. Apăs puțin pe musculatura de aici, spuneți-mi dacă doare."
    },
    {
      "start": 120.32,
      "end": 122.22,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo e mai rău."
    },
    {
      "start": 122.34,
      "end": 127.66,
      "speaker": "SPEAKER_00",
      "text": "Trapezul superior drept e foarte contractat. Și zona asta de la baza gâtului, doare?"
    },
    {
      "start": 127.78,
      "end": 128.58,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 128.7,
      "end": 143.14,
      "speaker": "SPEAKER_00",
      "text": "Deci avem o contractură la nivel cervical cu iradiere în umărul drept, cel mai probabil din postura de la birou. O să lucrăm să reducem contractura, să eliberăm mobilitatea cervicală și să decontracturăm trapezul. Bun, haideți pe masă."
    }
  ]
}
