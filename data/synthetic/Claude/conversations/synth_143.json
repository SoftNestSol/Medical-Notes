      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule."
    },
    {
      "start": 1.26,
      "end": 2.06,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.18,
      "end": 4.08,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi numele, vă rog."
    },
    {
      "start": 4.2,
      "end": 5.0,
      "speaker": "SPEAKER_01",
      "text": "Dumitru Coman."
    },
    {
      "start": 5.12,
      "end": 5.92,
      "speaker": "SPEAKER_00",
      "text": "Și vârsta?"
    },
    {
      "start": 6.04,
      "end": 6.84,
      "speaker": "SPEAKER_01",
      "text": "51."
    },
    {
      "start": 6.96,
      "end": 10.38,
      "speaker": "SPEAKER_00",
      "text": "Mulțumesc, domnule Coman. Cu ce problemă ne vedem azi?"
    },
    {
      "start": 10.5,
      "end": 11.64,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 11.76,
      "end": 13.28,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De cât timp?"
    },
    {
      "start": 13.4,
      "end": 14.54,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 14.66,
      "end": 17.7,
      "speaker": "SPEAKER_00",
      "text": "Vreo două săptămâni. A apărut brusc sau treptat?"
    },
    {
      "start": 17.82,
      "end": 18.62,
      "speaker": "SPEAKER_01",
      "text": "Treptat."
    },
    {
      "start": 18.74,
      "end": 22.16,
      "speaker": "SPEAKER_00",
      "text": "Treptat. Și doare constant sau mai vine, mai trece?"
    },
    {
      "start": 22.28,
      "end": 23.08,
      "speaker": "SPEAKER_01",
      "text": "Constant."
    },
    {
      "start": 23.2,
      "end": 28.52,
      "speaker": "SPEAKER_00",
      "text": "Constant. Se lasă durerea și pe braț în jos sau e doar la gât?"
    },
    {
      "start": 28.64,
      "end": 30.16,
      "speaker": "SPEAKER_01",
      "text": "Și pe umăr puțin."
    },
    {
      "start": 30.28,
      "end": 32.56,
      "speaker": "SPEAKER_00",
      "text": "Pe ce umăr, dreptul sau stângul?"
    },
    {
      "start": 32.68,
      "end": 33.48,
      "speaker": "SPEAKER_01",
      "text": "Dreptul."
    },
    {
      "start": 33.6,
      "end": 37.4,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul drept. Mai jos de umăr nu se lasă?"
    },
    {
      "start": 37.52,
      "end": 38.32,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 38.44,
      "end": 47.56,
      "speaker": "SPEAKER_00",
      "text": "Nu. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, cât de tare doare gâtul?"
    },
    {
      "start": 47.68,
      "end": 48.48,
      "speaker": "SPEAKER_01",
      "text": "Vreo 6."
    },
    {
      "start": 48.6,
      "end": 50.5,
      "speaker": "SPEAKER_00",
      "text": "Vreo 6. Și umărul drept?"
    },
    {
      "start": 50.62,
      "end": 52.14,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin, un 4."
    },
    {
      "start": 52.26,
      "end": 56.06,
      "speaker": "SPEAKER_00",
      "text": "Un 4, bine. Lucrați la birou, stați mult la calculator?"
    },
    {
      "start": 56.18,
      "end": 56.98,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 57.1,
      "end": 59.0,
      "speaker": "SPEAKER_00",
      "text": "Câte ore pe zi aproximativ?"
    },
    {
      "start": 59.12,
      "end": 60.26,
      "speaker": "SPEAKER_01",
      "text": "Vreo 8-9."
    },
    {
      "start": 60.38,
      "end": 65.32,
      "speaker": "SPEAKER_00",
      "text": "8-9 ore. Și stați cu capul aplecat sau cu monitorul în față?"
    },
    {
      "start": 65.44,
      "end": 66.24,
      "speaker": "SPEAKER_01",
      "text": "Cam aplecat."
    },
    {
      "start": 66.36,
      "end": 68.64,
      "speaker": "SPEAKER_00",
      "text": "Cam aplecat, înțeles. Tensiune arterială aveți?"
    },
    {
      "start": 68.76,
      "end": 69.56,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 69.68,
      "end": 71.58,
      "speaker": "SPEAKER_00",
      "text": "Și luați ceva pentru tensiune?"
    },
    {
      "start": 71.7,
      "end": 72.5,
      "speaker": "SPEAKER_01",
      "text": "Da, Prestarium."
    },
    {
      "start": 72.62,
      "end": 74.14,
      "speaker": "SPEAKER_00",
      "text": "Prestarium. Știți ce doză?"
    },
    {
      "start": 74.26,
      "end": 75.06,
      "speaker": "SPEAKER_01",
      "text": "5 miligrame."
    },
    {
      "start": 75.18,
      "end": 77.46,
      "speaker": "SPEAKER_00",
      "text": "5 miligrame, bine. Altceva mai luați?"
    },
    {
      "start": 77.58,
      "end": 78.38,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 78.5,
      "end": 80.78,
      "speaker": "SPEAKER_00",
      "text": "Alte afecțiuni, diabet, epilepsie, scolioză, osteoporoză?"
    },
    {
      "start": 80.9,
      "end": 81.7,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 81.82,
      "end": 82.96,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale, fracturi?"
    },
    {
      "start": 83.08,
      "end": 83.88,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 84.0,
      "end": 91.22,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să stați în picioare un moment. Vreau să vedem cum vă mișcați capul. Înclinați ușor spre dreapta."
    },
    {
      "start": 91.34,
      "end": 92.14,
      "speaker": "SPEAKER_01",
      "text": "Doare."
    },
    {
      "start": 92.26,
      "end": 95.3,
      "speaker": "SPEAKER_00",
      "text": "Doare la înclinarea spre dreapta. Și spre stânga?"
    },
    {
      "start": 95.42,
      "end": 96.22,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 96.34,
      "end": 99.0,
      "speaker": "SPEAKER_00",
      "text": "Mai puțin spre stânga. Rotație spre dreapta?"
    },
    {
      "start": 99.12,
      "end": 100.64,
      "speaker": "SPEAKER_01",
      "text": "Da, doare și acolo."
    },
    {
      "start": 100.76,
      "end": 106.84,
      "speaker": "SPEAKER_00",
      "text": "Și acolo. Bun, o să apăs puțin pe zona de cervical, spuneți-mi dacă simțiți ceva."
    },
    {
      "start": 106.96,
      "end": 107.76,
      "speaker": "SPEAKER_01",
      "text": "Acolo, da."
    },
    {
      "start": 107.88,
      "end": 126.5,
      "speaker": "SPEAKER_00",
      "text": "Da, simț o contractură destul de serioasă pe zona de trapez și pe cervicalul inferior, pe dreapta mai ales. Pare o cervicalgie cu iradiere în umăr, probabil de la postura la calculator. O să lucrăm să reducem contractura și să recăpătăm mobilitatea în cervical. Haideți pe masă, vă rog."
    }
  ]
}
