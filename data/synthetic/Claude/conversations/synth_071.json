{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua."
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 4.12,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem azi?"
    },
    {
      "start": 4.24,
      "end": 5.38,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 5.5,
      "end": 6.3,
      "speaker": "SPEAKER_00",
      "text": "De când?"
    },
    {
      "start": 6.42,
      "end": 7.94,
      "speaker": "SPEAKER_01",
      "text": "De vreo două săptămâni."
    },
    {
      "start": 8.06,
      "end": 10.34,
      "speaker": "SPEAKER_00",
      "text": "Și a apărut brusc sau treptat?"
    },
    {
      "start": 10.46,
      "end": 11.26,
      "speaker": "SPEAKER_01",
      "text": "Treptat."
    },
    {
      "start": 11.38,
      "end": 14.8,
      "speaker": "SPEAKER_00",
      "text": "Aveți o muncă de birou, stați mult la calculator?"
    },
    {
      "start": 14.92,
      "end": 15.72,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 15.84,
      "end": 21.16,
      "speaker": "SPEAKER_00",
      "text": "Durerea rămâne doar în zona gâtului sau se lasă și pe umăr, pe braț?"
    },
    {
      "start": 21.28,
      "end": 23.56,
      "speaker": "SPEAKER_01",
      "text": "Și pe umărul drept un pic."
    },
    {
      "start": 23.68,
      "end": 28.62,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul drept. Mai departe de umăr, pe braț, pe mână, simțiți ceva?"
    },
    {
      "start": 28.74,
      "end": 29.54,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 29.66,
      "end": 30.8,
      "speaker": "SPEAKER_00",
      "text": "Amorțeli la mână?"
    },
    {
      "start": 30.92,
      "end": 31.72,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 31.84,
      "end": 39.82,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, unde situați durerea?"
    },
    {
      "start": 39.94,
      "end": 40.74,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 40.86,
      "end": 43.52,
      "speaker": "SPEAKER_00",
      "text": "5. Dimineața e mai rău sau seara?"
    },
    {
      "start": 43.64,
      "end": 44.44,
      "speaker": "SPEAKER_01",
      "text": "Seara."
    },
    {
      "start": 44.56,
      "end": 46.84,
      "speaker": "SPEAKER_00",
      "text": "Seara după ce stați la birou."
    },
    {
      "start": 46.96,
      "end": 47.76,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 47.88,
      "end": 50.54,
      "speaker": "SPEAKER_00",
      "text": "Ați luat ceva pentru durere, vreun medicament?"
    },
    {
      "start": 50.66,
      "end": 51.46,
      "speaker": "SPEAKER_01",
      "text": "Ibuprofen, uneori."
    },
    {
      "start": 51.58,
      "end": 52.72,
      "speaker": "SPEAKER_00",
      "text": "Cât, ce doză?"
    },
    {
      "start": 52.84,
      "end": 54.74,
      "speaker": "SPEAKER_01",
      "text": "Nu știu exact. 400, cred."
    },
    {
      "start": 54.86,
      "end": 57.14,
      "speaker": "SPEAKER_00",
      "text": "400 de miligrame. Cât de des?"
    },
    {
      "start": 57.26,
      "end": 61.44,
      "speaker": "SPEAKER_01",
      "text": "Când nu mai suport. O dată, de două ori pe săptămână."
    },
    {
      "start": 61.56,
      "end": 63.46,
      "speaker": "SPEAKER_00",
      "text": "Am înțeles. Alergii la medicamente?"
    },
    {
      "start": 63.58,
      "end": 64.38,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 64.5,
      "end": 67.54,
      "speaker": "SPEAKER_00",
      "text": "Alte afecțiuni, tensiune, diabet, hernie de disc diagnosticată?"
    },
    {
      "start": 67.66,
      "end": 68.46,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 68.58,
      "end": 71.62,
      "speaker": "SPEAKER_00",
      "text": "Ați mai avut probleme la coloana cervicală înainte?"
    },
    {
      "start": 71.74,
      "end": 72.88,
      "speaker": "SPEAKER_01",
      "text": "Nu, prima oară."
    },
    {
      "start": 73.0,
      "end": 78.32,
      "speaker": "SPEAKER_00",
      "text": "Prima oară. Ok. Haideți să facem câteva teste rapide. Întoarceți capul spre dreapta încet."
    },
    {
      "start": 78.44,
      "end": 79.24,
      "speaker": "SPEAKER_01",
      "text": "Mm."
    },
    {
      "start": 79.36,
      "end": 80.16,
      "speaker": "SPEAKER_00",
      "text": "Doare?"
    },
    {
      "start": 80.28,
      "end": 81.42,
      "speaker": "SPEAKER_01",
      "text": "Da, un pic."
    },
    {
      "start": 81.54,
      "end": 82.68,
      "speaker": "SPEAKER_00",
      "text": "Și spre stânga?"
    },
    {
      "start": 82.8,
      "end": 83.6,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 83.72,
      "end": 85.62,
      "speaker": "SPEAKER_00",
      "text": "Bun. Lăsați capul pe spate."
    },
    {
      "start": 85.74,
      "end": 86.88,
      "speaker": "SPEAKER_01",
      "text": "Doare mai tare."
    },
    {
      "start": 87.0,
      "end": 94.22,
      "speaker": "SPEAKER_00",
      "text": "Doare mai tare în extensie, da. Apăs acum pe mușchii de la baza gâtului, îmi spuneți dacă simțiți ceva."
    },
    {
      "start": 94.34,
      "end": 95.48,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo doare."
    },
    {
      "start": 95.6,
      "end": 97.12,
      "speaker": "SPEAKER_00",
      "text": "Pe dreapta mai mult?"
    },
    {
      "start": 97.24,
      "end": 98.04,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 98.16,
      "end": 114.5,
      "speaker": "SPEAKER_00",
      "text": "Am înțeles. Postura la birou nu e tocmai bună, gâtul e dus în față. Vedem o contractură pe partea dreaptă, trapez și paravertebral cervical. Mobilitatea e redusă la extensie și rotație dreapta. O să lucrăm să reducem contractura și să recuperăm mobilitatea cervicală."
    },
    {
      "start": 114.62,
      "end": 115.42,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 115.54,
      "end": 121.24,
      "speaker": "SPEAKER_00",
      "text": "Ședința de astăzi o să fie de masaj și mobilizare. Vedem cum vă simțiți după."
    },
    {
      "start": 121.36,
      "end": 122.16,
      "speaker": "SPEAKER_01",
      "text": "Bine."
    }
  ]
}
