{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua!"
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 1.84,
      "end": 4.12,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem astăzi?"
    },
    {
      "start": 4.24,
      "end": 5.38,
      "speaker": "SPEAKER_01",
      "text": "Mă doare umărul."
    },
    {
      "start": 5.5,
      "end": 7.4,
      "speaker": "SPEAKER_00",
      "text": "Care umăr, dreptul sau stângul?"
    },
    {
      "start": 7.52,
      "end": 8.32,
      "speaker": "SPEAKER_01",
      "text": "Dreptul."
    },
    {
      "start": 8.44,
      "end": 9.58,
      "speaker": "SPEAKER_00",
      "text": "De cât timp?"
    },
    {
      "start": 9.7,
      "end": 10.84,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 10.96,
      "end": 13.24,
      "speaker": "SPEAKER_00",
      "text": "Și a apărut brusc sau treptat?"
    },
    {
      "start": 13.36,
      "end": 14.16,
      "speaker": "SPEAKER_01",
      "text": "Treptat."
    },
    {
      "start": 14.28,
      "end": 16.94,
      "speaker": "SPEAKER_00",
      "text": "A fost vreo lovitură, vreo căzătură, ceva?"
    },
    {
      "start": 17.06,
      "end": 17.86,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 17.98,
      "end": 18.78,
      "speaker": "SPEAKER_00",
      "text": "Nicio traumă."
    },
    {
      "start": 18.9,
      "end": 19.7,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 19.82,
      "end": 24.0,
      "speaker": "SPEAKER_00",
      "text": "Și ce faceți în mod curent, lucrați la birou, ceva fizic?"
    },
    {
      "start": 24.12,
      "end": 25.26,
      "speaker": "SPEAKER_01",
      "text": "La birou, da."
    },
    {
      "start": 25.38,
      "end": 26.9,
      "speaker": "SPEAKER_00",
      "text": "Mult timp la calculator?"
    },
    {
      "start": 27.02,
      "end": 28.16,
      "speaker": "SPEAKER_01",
      "text": "Cam toată ziua."
    },
    {
      "start": 28.28,
      "end": 33.6,
      "speaker": "SPEAKER_00",
      "text": "Am înțeles. Pe o scară de la 0 la 10, cât de tare doare?"
    },
    {
      "start": 33.72,
      "end": 34.52,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 34.64,
      "end": 36.92,
      "speaker": "SPEAKER_00",
      "text": "Doare constant sau doar la mișcare?"
    },
    {
      "start": 37.04,
      "end": 38.56,
      "speaker": "SPEAKER_01",
      "text": "Mai mult la mișcare."
    },
    {
      "start": 38.68,
      "end": 40.58,
      "speaker": "SPEAKER_00",
      "text": "Ce fel de mișcare anume?"
    },
    {
      "start": 40.7,
      "end": 41.84,
      "speaker": "SPEAKER_01",
      "text": "Când ridic brațul."
    },
    {
      "start": 41.96,
      "end": 44.24,
      "speaker": "SPEAKER_00",
      "text": "Ridici brațul în față, deasupra capului?"
    },
    {
      "start": 44.36,
      "end": 45.88,
      "speaker": "SPEAKER_01",
      "text": "Da, mai ales deasupra."
    },
    {
      "start": 46.0,
      "end": 50.94,
      "speaker": "SPEAKER_00",
      "text": "Se lasă durerea și pe braț în jos sau rămâne locală la umăr?"
    },
    {
      "start": 51.06,
      "end": 51.86,
      "speaker": "SPEAKER_01",
      "text": "Rămâne acolo."
    },
    {
      "start": 51.98,
      "end": 54.26,
      "speaker": "SPEAKER_00",
      "text": "Noaptea te trezești din cauza ei?"
    },
    {
      "start": 54.38,
      "end": 55.18,
      "speaker": "SPEAKER_01",
      "text": "Uneori."
    },
    {
      "start": 55.3,
      "end": 57.2,
      "speaker": "SPEAKER_00",
      "text": "Uneori. Dormi pe partea dreaptă?"
    },
    {
      "start": 57.32,
      "end": 58.12,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 58.24,
      "end": 60.9,
      "speaker": "SPEAKER_00",
      "text": "Aha, deci apăsând pe umărul ăla. Alergii?"
    },
    {
      "start": 61.02,
      "end": 61.82,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 61.94,
      "end": 65.36,
      "speaker": "SPEAKER_00",
      "text": "Afecțiuni mai vechi, tensiune, diabet, osteoporoză, ceva de genul?"
    },
    {
      "start": 65.48,
      "end": 66.28,
      "speaker": "SPEAKER_01",
      "text": "Nu, nimic."
    },
    {
      "start": 66.4,
      "end": 69.06,
      "speaker": "SPEAKER_00",
      "text": "Iei vreun medicament în momentul de față?"
    },
    {
      "start": 69.18,
      "end": 69.98,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 70.1,
      "end": 71.24,
      "speaker": "SPEAKER_00",
      "text": "Niciun supliment, nimic?"
    },
    {
      "start": 71.36,
      "end": 72.16,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 72.28,
      "end": 75.7,
      "speaker": "SPEAKER_00",
      "text": "Ok. Ai făcut vreun RMN sau radiografie pe umăr?"
    },
    {
      "start": 75.82,
      "end": 76.62,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 76.74,
      "end": 82.06,
      "speaker": "SPEAKER_00",
      "text": "Bine. Haideți să facem câteva teste. Ridică brațul lateral, ușor... spune-mi când doare."
    },
    {
      "start": 82.18,
      "end": 83.32,
      "speaker": "SPEAKER_01",
      "text": "Cam de aici."
    },
    {
      "start": 83.44,
      "end": 88.76,
      "speaker": "SPEAKER_00",
      "text": "Deci la aproximativ 80-90 de grade apare durerea. Încearcă să ridici mai sus."
    },
    {
      "start": 88.88,
      "end": 90.4,
      "speaker": "SPEAKER_01",
      "text": "Au, nu mai pot."
    },
    {
      "start": 90.52,
      "end": 96.98,
      "speaker": "SPEAKER_00",
      "text": "Ok, ne oprim. Acum rotește brațul în exterior, cu cotul la 90 de grade, ca o aripă."
    },
    {
      "start": 97.1,
      "end": 98.24,
      "speaker": "SPEAKER_01",
      "text": "Doare un pic."
    },
    {
      "start": 98.36,
      "end": 104.82,
      "speaker": "SPEAKER_00",
      "text": "Doare la rotație externă. Apăs acum pe zona asta de pe umăr, spune-mi dacă e sensibil."
    },
    {
      "start": 104.94,
      "end": 106.08,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo doare."
    },
    {
      "start": 106.2,
      "end": 123.3,
      "speaker": "SPEAKER_00",
      "text": "Exact pe inserția mușchiului supraspinos. Bine. Deci avem o limitare de mobilitate în abducție și durere la palpare pe rotator cuff. Cel mai probabil o tendinopatie la nivelul umărului drept, posibil și un conflict subacomial. Vom lucra să reducem inflamația și să refacem mobilitatea umărului."
    },
    {
      "start": 123.42,
      "end": 124.22,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 124.34,
      "end": 132.32,
      "speaker": "SPEAKER_00",
      "text": "Câteva ședințe și ar trebui să simți o îmbunătățire. Dacă nu se remite, ar fi bine să facem și un RMN."
    },
    {
      "start": 132.44,
      "end": 133.24,
      "speaker": "SPEAKER_01",
      "text": "Înțeles."
    }
  ]
}
