{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.14,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule."
    },
    {
      "start": 1.26,
      "end": 2.06,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.18,
      "end": 3.32,
      "speaker": "SPEAKER_00",
      "text": "Cum vă numiți?"
    },
    {
      "start": 3.44,
      "end": 4.58,
      "speaker": "SPEAKER_01",
      "text": "Matei. Bogdan Matei."
    },
    {
      "start": 4.7,
      "end": 8.88,
      "speaker": "SPEAKER_00",
      "text": "Bogdan Matei, bine ați venit. Cu ce problemă ne vedem astăzi?"
    },
    {
      "start": 9.0,
      "end": 10.14,
      "speaker": "SPEAKER_01",
      "text": "Mă doare umărul."
    },
    {
      "start": 10.26,
      "end": 11.06,
      "speaker": "SPEAKER_00",
      "text": "Care umăr?"
    },
    {
      "start": 11.18,
      "end": 11.98,
      "speaker": "SPEAKER_01",
      "text": "Cel drept."
    },
    {
      "start": 12.1,
      "end": 13.62,
      "speaker": "SPEAKER_00",
      "text": "De când vă doare?"
    },
    {
      "start": 13.74,
      "end": 15.26,
      "speaker": "SPEAKER_01",
      "text": "De vreo două săptămâni."
    },
    {
      "start": 15.38,
      "end": 19.94,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. A apărut după ceva anume, după un efort, o lovitură?"
    },
    {
      "start": 20.06,
      "end": 22.72,
      "speaker": "SPEAKER_01",
      "text": "Am cărat niște cutii grele la muncă."
    },
    {
      "start": 22.84,
      "end": 25.88,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Doare constant sau numai când mișcați mâna?"
    },
    {
      "start": 26.0,
      "end": 26.8,
      "speaker": "SPEAKER_01",
      "text": "Când mișc."
    },
    {
      "start": 26.92,
      "end": 28.44,
      "speaker": "SPEAKER_00",
      "text": "Când ridicați brațul doare?"
    },
    {
      "start": 28.56,
      "end": 29.36,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 29.48,
      "end": 31.76,
      "speaker": "SPEAKER_00",
      "text": "Și când duceți mâna în spate?"
    },
    {
      "start": 31.88,
      "end": 33.02,
      "speaker": "SPEAKER_01",
      "text": "Da, mai rău."
    },
    {
      "start": 33.14,
      "end": 39.6,
      "speaker": "SPEAKER_00",
      "text": "Mai rău. Pe o scară de la 0 la 10, cât de tare doare când ridicați brațul?"
    },
    {
      "start": 39.72,
      "end": 40.52,
      "speaker": "SPEAKER_01",
      "text": "Vreo 7."
    },
    {
      "start": 40.64,
      "end": 42.92,
      "speaker": "SPEAKER_00",
      "text": "7. Și noaptea vă trezește durerea?"
    },
    {
      "start": 43.04,
      "end": 43.84,
      "speaker": "SPEAKER_01",
      "text": "Câteodată."
    },
    {
      "start": 43.96,
      "end": 45.86,
      "speaker": "SPEAKER_00",
      "text": "Câteodată. Amorțește mâna sau degetele?"
    },
    {
      "start": 45.98,
      "end": 46.78,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 46.9,
      "end": 50.7,
      "speaker": "SPEAKER_00",
      "text": "Nu. Bun. Ridicați brațul pentru mine, cât puteți de sus."
    },
    {
      "start": 50.82,
      "end": 54.24,
      "speaker": "SPEAKER_01",
      "text": "Până pe la... nu pot mai sus de atât."
    },
    {
      "start": 54.36,
      "end": 57.02,
      "speaker": "SPEAKER_00",
      "text": "Până la vreo 90 de grade, da?"
    },
    {
      "start": 57.14,
      "end": 57.94,
      "speaker": "SPEAKER_01",
      "text": "Cam așa."
    },
    {
      "start": 58.06,
      "end": 61.86,
      "speaker": "SPEAKER_00",
      "text": "Stați puțin. Doare acum când apăs aici, pe zona asta?"
    },
    {
      "start": 61.98,
      "end": 62.78,
      "speaker": "SPEAKER_01",
      "text": "Da, da."
    },
    {
      "start": 62.9,
      "end": 65.94,
      "speaker": "SPEAKER_00",
      "text": "Și dacă rotesc ușor brațul spre exterior, doare?"
    },
    {
      "start": 66.06,
      "end": 66.86,
      "speaker": "SPEAKER_01",
      "text": "Au, da."
    },
    {
      "start": 66.98,
      "end": 71.16,
      "speaker": "SPEAKER_00",
      "text": "Bine. Avem alte afecțiuni, tensiune, diabet, osteoporoză, ceva de felul ăsta?"
    },
    {
      "start": 71.28,
      "end": 72.08,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 72.2,
      "end": 73.0,
      "speaker": "SPEAKER_00",
      "text": "Nicio afecțiune?"
    },
    {
      "start": 73.12,
      "end": 73.92,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 74.04,
      "end": 75.94,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale la umăr vreodată?"
    },
    {
      "start": 76.06,
      "end": 76.86,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 76.98,
      "end": 78.5,
      "speaker": "SPEAKER_00",
      "text": "Luați vreun medicament acum?"
    },
    {
      "start": 78.62,
      "end": 81.28,
      "speaker": "SPEAKER_01",
      "text": "Iau un ibuprofen din când în când."
    },
    {
      "start": 81.4,
      "end": 82.54,
      "speaker": "SPEAKER_00",
      "text": "Cât de des?"
    },
    {
      "start": 82.66,
      "end": 85.7,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, câte unul la două zile poate."
    },
    {
      "start": 85.82,
      "end": 87.34,
      "speaker": "SPEAKER_00",
      "text": "La două zile, doza?"
    },
    {
      "start": 87.46,
      "end": 88.26,
      "speaker": "SPEAKER_01",
      "text": "400."
    },
    {
      "start": 88.38,
      "end": 90.66,
      "speaker": "SPEAKER_00",
      "text": "400 de miligrame. Altceva nu luați?"
    },
    {
      "start": 90.78,
      "end": 91.58,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 91.7,
      "end": 93.6,
      "speaker": "SPEAKER_00",
      "text": "Alergii la creme sau unguente?"
    },
    {
      "start": 93.72,
      "end": 94.52,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 94.64,
      "end": 112.12,
      "speaker": "SPEAKER_00",
      "text": "Bine. Deci avem o inflamație la nivelul coafei rotatorilor, cel mai probabil tendonul supraspinos este afectat. Mobilitatea este limitată, nu puteți ridica brațul peste 90 de grade, rotația externă este dureroasă. Obiectivul nostru în prima fază e să reducem inflamația și să recâștigăm amplitudinea de mișcare."
    },
    {
      "start": 112.24,
      "end": 113.04,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 113.16,
      "end": 114.3,
      "speaker": "SPEAKER_00",
      "text": "Haideți să începem."
    }
  ]
}
