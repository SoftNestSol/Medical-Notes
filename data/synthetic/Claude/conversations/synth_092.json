  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua."
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 3.74,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă venim azi?"
    },
    {
      "start": 3.86,
      "end": 5.0,
      "speaker": "SPEAKER_01",
      "text": "Mă doare spatele."
    },
    {
      "start": 5.12,
      "end": 6.64,
      "speaker": "SPEAKER_00",
      "text": "Zona de jos, sus?"
    },
    {
      "start": 6.76,
      "end": 7.56,
      "speaker": "SPEAKER_01",
      "text": "Jos."
    },
    {
      "start": 7.68,
      "end": 8.48,
      "speaker": "SPEAKER_00",
      "text": "Lombar, da?"
    },
    {
      "start": 8.6,
      "end": 9.4,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 9.52,
      "end": 10.66,
      "speaker": "SPEAKER_00",
      "text": "De cât timp?"
    },
    {
      "start": 10.78,
      "end": 11.92,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 12.04,
      "end": 16.22,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. Și a apărut din senin sau ați făcut ceva?"
    },
    {
      "start": 16.34,
      "end": 18.62,
      "speaker": "SPEAKER_01",
      "text": "Am ridicat niște saci la muncă."
    },
    {
      "start": 18.74,
      "end": 22.16,
      "speaker": "SPEAKER_00",
      "text": "Saci, deci efort fizic. Și de atunci mă doare?"
    },
    {
      "start": 22.28,
      "end": 23.08,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 23.2,
      "end": 31.56,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare cel mai tare, unde o situați?"
    },
    {
      "start": 31.68,
      "end": 32.48,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 32.6,
      "end": 36.02,
      "speaker": "SPEAKER_00",
      "text": "5. Doare tot timpul sau numai când faceți ceva?"
    },
    {
      "start": 36.14,
      "end": 38.04,
      "speaker": "SPEAKER_01",
      "text": "Mai mult când mă mișc."
    },
    {
      "start": 38.16,
      "end": 40.44,
      "speaker": "SPEAKER_00",
      "text": "Când vă aplecați, când vă ridicați?"
    },
    {
      "start": 40.56,
      "end": 42.84,
      "speaker": "SPEAKER_01",
      "text": "Da, și când stau jos mult."
    },
    {
      "start": 42.96,
      "end": 48.66,
      "speaker": "SPEAKER_00",
      "text": "Când stați pe scaun mult timp. Durerea se lasă și pe picior, pe fesă, undeva?"
    },
    {
      "start": 48.78,
      "end": 49.58,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 49.7,
      "end": 50.84,
      "speaker": "SPEAKER_00",
      "text": "Strict în spate?"
    },
    {
      "start": 50.96,
      "end": 51.76,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 51.88,
      "end": 53.02,
      "speaker": "SPEAKER_00",
      "text": "Amorțeli la picioare?"
    },
    {
      "start": 53.14,
      "end": 53.94,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 54.06,
      "end": 57.48,
      "speaker": "SPEAKER_00",
      "text": "Bun. Ați mai avut episoade de genul ăsta înainte?"
    },
    {
      "start": 57.6,
      "end": 59.5,
      "speaker": "SPEAKER_01",
      "text": "Acum doi ani, ceva similar."
    },
    {
      "start": 59.62,
      "end": 61.52,
      "speaker": "SPEAKER_00",
      "text": "Și atunci ce ați făcut?"
    },
    {
      "start": 61.64,
      "end": 64.3,
      "speaker": "SPEAKER_01",
      "text": "Am luat niște pastile și a trecut."
    },
    {
      "start": 64.42,
      "end": 65.56,
      "speaker": "SPEAKER_00",
      "text": "Ce pastile, știți?"
    },
    {
      "start": 65.68,
      "end": 67.58,
      "speaker": "SPEAKER_01",
      "text": "Nu știu exact. Ceva antiinflamator."
    },
    {
      "start": 67.7,
      "end": 69.22,
      "speaker": "SPEAKER_00",
      "text": "Antiinflamator. Acum luați ceva?"
    },
    {
      "start": 69.34,
      "end": 70.14,
      "speaker": "SPEAKER_01",
      "text": "Ibuprofen."
    },
    {
      "start": 70.26,
      "end": 71.06,
      "speaker": "SPEAKER_00",
      "text": "Cât ibuprofen?"
    },
    {
      "start": 71.18,
      "end": 73.08,
      "speaker": "SPEAKER_01",
      "text": "400, o pastilă pe zi."
    },
    {
      "start": 73.2,
      "end": 76.24,
      "speaker": "SPEAKER_00",
      "text": "O pastilă de 400 pe zi. De când?"
    },
    {
      "start": 76.36,
      "end": 77.5,
      "speaker": "SPEAKER_01",
      "text": "De vreo săptămână."
    },
    {
      "start": 77.62,
      "end": 80.28,
      "speaker": "SPEAKER_00",
      "text": "Ok. Alte afecțiuni, tensiune, diabet, osteoporoză, altceva?"
    },
    {
      "start": 80.4,
      "end": 81.2,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 81.32,
      "end": 82.84,
      "speaker": "SPEAKER_00",
      "text": "Nicio operație, nicio fractură?"
    },
    {
      "start": 82.96,
      "end": 83.76,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 83.88,
      "end": 88.82,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să vă uit puțin. Stați în picioare cu spatele la mine."
    },
    {
      "start": 88.94,
      "end": 89.74,
      "speaker": "SPEAKER_01",
      "text": "Asa?"
    },
    {
      "start": 89.86,
      "end": 92.14,
      "speaker": "SPEAKER_00",
      "text": "Da. Aplecați-vă ușor în față."
    },
    {
      "start": 92.26,
      "end": 93.06,
      "speaker": "SPEAKER_01",
      "text": "Doare aici."
    },
    {
      "start": 93.18,
      "end": 96.22,
      "speaker": "SPEAKER_00",
      "text": "Da, pe zona paravertebrală lombară. Și la revenire?"
    },
    {
      "start": 96.34,
      "end": 97.14,
      "speaker": "SPEAKER_01",
      "text": "La fel."
    },
    {
      "start": 97.26,
      "end": 102.96,
      "speaker": "SPEAKER_00",
      "text": "Văd o contractură pe dreapta mai pronunțată. Stați puțin pe piciorul drept, să vă țineți?"
    },
    {
      "start": 103.08,
      "end": 103.88,
      "speaker": "SPEAKER_01",
      "text": "Mă ține."
    },
    {
      "start": 104.0,
      "end": 108.56,
      "speaker": "SPEAKER_00",
      "text": "Bun. Vă apăs puțin pe paravertebral, spuneți-mi unde doare mai tare."
    },
    {
      "start": 108.68,
      "end": 109.48,
      "speaker": "SPEAKER_01",
      "text": "Aici, jos."
    },
    {
      "start": 109.6,
      "end": 112.26,
      "speaker": "SPEAKER_00",
      "text": "L4-L5, da. Pe stânga la fel?"
    },
    {
      "start": 112.38,
      "end": 113.18,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 113.3,
      "end": 125.08,
      "speaker": "SPEAKER_00",
      "text": "Deci mai mult pe dreapta. Ok, avem o lombalghe acută mecanică, contractură paravertebrală lombară, mai accentuată pe dreapta. Lucrăm să reducem contractura și inflamația și să recuperăm mobilitatea. Haideți pe masă."
    },
    {
      "start": 125.2,
      "end": 126.0,
      "speaker": "SPEAKER_01",
      "text": "Da."
    }
  ]
}
