{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua."
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 1.84,
      "end": 5.26,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi, vă rog, cu ce problemă veniți azi."
    },
    {
      "start": 5.38,
      "end": 6.52,
      "speaker": "SPEAKER_01",
      "text": "Mă doare umărul."
    },
    {
      "start": 6.64,
      "end": 7.44,
      "speaker": "SPEAKER_00",
      "text": "Care umăr?"
    },
    {
      "start": 7.56,
      "end": 8.36,
      "speaker": "SPEAKER_01",
      "text": "Stângul."
    },
    {
      "start": 8.48,
      "end": 9.62,
      "speaker": "SPEAKER_00",
      "text": "De cât timp?"
    },
    {
      "start": 9.74,
      "end": 10.88,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 11.0,
      "end": 14.8,
      "speaker": "SPEAKER_00",
      "text": "A apărut după ceva anume, după un efort, o căzătură?"
    },
    {
      "start": 14.92,
      "end": 20.24,
      "speaker": "SPEAKER_01",
      "text": "Nu știu exact. Am cărat niște cutii la muncă și după aia a început."
    },
    {
      "start": 20.36,
      "end": 21.88,
      "speaker": "SPEAKER_00",
      "text": "Deci după ridicat greutăți."
    },
    {
      "start": 22.0,
      "end": 22.8,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 22.92,
      "end": 25.58,
      "speaker": "SPEAKER_00",
      "text": "Doare tot timpul sau numai la mișcare?"
    },
    {
      "start": 25.7,
      "end": 27.22,
      "speaker": "SPEAKER_01",
      "text": "Mai mult la mișcare."
    },
    {
      "start": 27.34,
      "end": 29.24,
      "speaker": "SPEAKER_00",
      "text": "Când ridicați brațul sus doare?"
    },
    {
      "start": 29.36,
      "end": 30.5,
      "speaker": "SPEAKER_01",
      "text": "Da, doare rău."
    },
    {
      "start": 30.62,
      "end": 33.66,
      "speaker": "SPEAKER_00",
      "text": "Dar în spate, dacă duceți mâna la spate?"
    },
    {
      "start": 33.78,
      "end": 35.3,
      "speaker": "SPEAKER_01",
      "text": "Și aia doare, da."
    },
    {
      "start": 35.42,
      "end": 41.12,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, cât de tare doare când ridicați brațul?"
    },
    {
      "start": 41.24,
      "end": 42.04,
      "speaker": "SPEAKER_01",
      "text": "Vreo 7."
    },
    {
      "start": 42.16,
      "end": 44.44,
      "speaker": "SPEAKER_00",
      "text": "Și în repaus, noaptea, vă trezește?"
    },
    {
      "start": 44.56,
      "end": 47.22,
      "speaker": "SPEAKER_01",
      "text": "Câteodată, da, dacă stau pe partea aia."
    },
    {
      "start": 47.34,
      "end": 50.76,
      "speaker": "SPEAKER_00",
      "text": "Deci dacă stați pe umărul stâng noaptea vă doare."
    },
    {
      "start": 50.88,
      "end": 51.68,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 51.8,
      "end": 52.94,
      "speaker": "SPEAKER_00",
      "text": "Amorțește mâna, degetele?"
    },
    {
      "start": 53.06,
      "end": 53.86,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 53.98,
      "end": 56.64,
      "speaker": "SPEAKER_00",
      "text": "Bine. Doare și în zona gâtului, cervical?"
    },
    {
      "start": 56.76,
      "end": 57.56,
      "speaker": "SPEAKER_01",
      "text": "Nu, nu."
    },
    {
      "start": 57.68,
      "end": 58.48,
      "speaker": "SPEAKER_00",
      "text": "Strict umărul."
    },
    {
      "start": 58.6,
      "end": 59.4,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 59.52,
      "end": 62.56,
      "speaker": "SPEAKER_00",
      "text": "Ați mai avut probleme cu umărul ăsta înainte?"
    },
    {
      "start": 62.68,
      "end": 63.48,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 63.6,
      "end": 65.12,
      "speaker": "SPEAKER_00",
      "text": "Nicio luxație, nicio lovitură?"
    },
    {
      "start": 65.24,
      "end": 66.38,
      "speaker": "SPEAKER_01",
      "text": "Nu, prima dată."
    },
    {
      "start": 66.5,
      "end": 69.16,
      "speaker": "SPEAKER_00",
      "text": "Ok. Alte afecțiuni, tensiune, diabet, osteoporoză, cancer?"
    },
    {
      "start": 69.28,
      "end": 70.08,
      "speaker": "SPEAKER_01",
      "text": "Nu, nimic."
    },
    {
      "start": 70.2,
      "end": 71.0,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale?"
    },
    {
      "start": 71.12,
      "end": 71.92,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 72.04,
      "end": 73.56,
      "speaker": "SPEAKER_00",
      "text": "Medicamente luați în prezent?"
    },
    {
      "start": 73.68,
      "end": 74.48,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 74.6,
      "end": 76.12,
      "speaker": "SPEAKER_00",
      "text": "Alergii la creme, unguente?"
    },
    {
      "start": 76.24,
      "end": 77.04,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 77.16,
      "end": 84.38,
      "speaker": "SPEAKER_00",
      "text": "Bun. Hai să vă ridic eu brațul acum, stați relaxat. Doare când ajungem pe aici, la 90 de grade?"
    },
    {
      "start": 84.5,
      "end": 86.4,
      "speaker": "SPEAKER_01",
      "text": "Da, începe de pe acolo."
    },
    {
      "start": 86.52,
      "end": 87.66,
      "speaker": "SPEAKER_00",
      "text": "Și mai sus?"
    },
    {
      "start": 87.78,
      "end": 88.58,
      "speaker": "SPEAKER_01",
      "text": "Mai rău."
    },
    {
      "start": 88.7,
      "end": 95.92,
      "speaker": "SPEAKER_00",
      "text": "Ok. Acum ridic eu brațul și vă rog să opuneți rezistență, să nu mă lăsați să-l cobor. Doare?"
    },
    {
      "start": 96.04,
      "end": 96.84,
      "speaker": "SPEAKER_01",
      "text": "Da, aici."
    },
    {
      "start": 96.96,
      "end": 98.48,
      "speaker": "SPEAKER_00",
      "text": "Arătați-mi unde exact."
    },
    {
      "start": 98.6,
      "end": 100.12,
      "speaker": "SPEAKER_01",
      "text": "Aici, pe lateral, sus."
    },
    {
      "start": 100.24,
      "end": 108.98,
      "speaker": "SPEAKER_00",
      "text": "Pe zona de sus a umărului, deci pe supraspinos. Acum ducem brațul în față, la 90 de grade, și rezistați. Doare la fel?"
    },
    {
      "start": 109.1,
      "end": 110.24,
      "speaker": "SPEAKER_01",
      "text": "Puțin mai puțin."
    },
    {
      "start": 110.36,
      "end": 125.94,
      "speaker": "SPEAKER_00",
      "text": "Bun. Vedeți, avem o durere la abducție activă și la rezistență, ceea ce indică o inflamație la nivelul tendonului supraspinosului. Cel mai probabil o tendinopatie a coifului rotatorilor pe stânga. Trebuie să lucrăm să reducem inflamația și să refacem mobilitatea umărului."
    },
    {
      "start": 126.06,
      "end": 127.58,
      "speaker": "SPEAKER_01",
      "text": "Și o să treacă?"
    },
    {
      "start": 127.7,
      "end": 133.02,
      "speaker": "SPEAKER_00",
      "text": "Da, dacă lucrăm corect o să treacă. Haideți pe masă, cu fața în sus."
    }
  ]
}
