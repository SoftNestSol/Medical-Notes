{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua!"
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 4.12,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă veniți la noi?"
    },
    {
      "start": 4.24,
      "end": 5.38,
      "speaker": "SPEAKER_01",
      "text": "Mă doare umărul."
    },
    {
      "start": 5.5,
      "end": 6.3,
      "speaker": "SPEAKER_00",
      "text": "Care umăr?"
    },
    {
      "start": 6.42,
      "end": 7.22,
      "speaker": "SPEAKER_01",
      "text": "Stângul."
    },
    {
      "start": 7.34,
      "end": 8.14,
      "speaker": "SPEAKER_00",
      "text": "De când?"
    },
    {
      "start": 8.26,
      "end": 9.4,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 9.52,
      "end": 12.94,
      "speaker": "SPEAKER_00",
      "text": "S-a întâmplat ceva? Ați căzut, ați ridicat ceva?"
    },
    {
      "start": 13.06,
      "end": 14.58,
      "speaker": "SPEAKER_01",
      "text": "Am mutat niște mobilă."
    },
    {
      "start": 14.7,
      "end": 20.02,
      "speaker": "SPEAKER_00",
      "text": "Am înțeles. Pe o scară de la 0 la 10, cât de tare doare?"
    },
    {
      "start": 20.14,
      "end": 20.94,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 21.06,
      "end": 23.72,
      "speaker": "SPEAKER_00",
      "text": "Doare constant sau numai când faceți ceva?"
    },
    {
      "start": 23.84,
      "end": 25.36,
      "speaker": "SPEAKER_01",
      "text": "Numai când ridic mâna."
    },
    {
      "start": 25.48,
      "end": 28.52,
      "speaker": "SPEAKER_00",
      "text": "Când ridicați mâna în față, în lateral, cum?"
    },
    {
      "start": 28.64,
      "end": 30.16,
      "speaker": "SPEAKER_01",
      "text": "Mai mult în lateral."
    },
    {
      "start": 30.28,
      "end": 33.7,
      "speaker": "SPEAKER_00",
      "text": "Ridicați mâna ușor în lateral acum. Până unde puteți?"
    },
    {
      "start": 33.82,
      "end": 34.96,
      "speaker": "SPEAKER_01",
      "text": "Până aici, cam."
    },
    {
      "start": 35.08,
      "end": 38.5,
      "speaker": "SPEAKER_00",
      "text": "Deci cam 90 de grade și după aceea doare?"
    },
    {
      "start": 38.62,
      "end": 39.42,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 39.54,
      "end": 41.06,
      "speaker": "SPEAKER_00",
      "text": "Și noaptea vă deranjează?"
    },
    {
      "start": 41.18,
      "end": 43.46,
      "speaker": "SPEAKER_01",
      "text": "Dacă stau pe umărul ăla, da."
    },
    {
      "start": 43.58,
      "end": 44.72,
      "speaker": "SPEAKER_00",
      "text": "Amorțește vreodată brațul?"
    },
    {
      "start": 44.84,
      "end": 45.64,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 45.76,
      "end": 49.94,
      "speaker": "SPEAKER_00",
      "text": "Durerea se lasă și pe braț sau e strict în umăr?"
    },
    {
      "start": 50.06,
      "end": 52.34,
      "speaker": "SPEAKER_01",
      "text": "E mai mult aici, în umăr."
    },
    {
      "start": 52.46,
      "end": 54.74,
      "speaker": "SPEAKER_00",
      "text": "Ați mai pățit asta cu umărul?"
    },
    {
      "start": 54.86,
      "end": 55.66,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 55.78,
      "end": 58.44,
      "speaker": "SPEAKER_00",
      "text": "Aveți hipertensiune, diabet, alte probleme de sănătate?"
    },
    {
      "start": 58.56,
      "end": 60.46,
      "speaker": "SPEAKER_01",
      "text": "Am tensiunea un pic ridicată."
    },
    {
      "start": 60.58,
      "end": 62.1,
      "speaker": "SPEAKER_00",
      "text": "Luați medicamente pentru tensiune?"
    },
    {
      "start": 62.22,
      "end": 63.02,
      "speaker": "SPEAKER_01",
      "text": "Da, Prestarium."
    },
    {
      "start": 63.14,
      "end": 63.94,
      "speaker": "SPEAKER_00",
      "text": "Ce doză?"
    },
    {
      "start": 64.06,
      "end": 65.96,
      "speaker": "SPEAKER_01",
      "text": "Nu știu exact. 5, parcă."
    },
    {
      "start": 66.08,
      "end": 67.6,
      "speaker": "SPEAKER_00",
      "text": "5 mg. Altceva luați?"
    },
    {
      "start": 67.72,
      "end": 68.52,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 68.64,
      "end": 69.44,
      "speaker": "SPEAKER_00",
      "text": "Operații, fracturi?"
    },
    {
      "start": 69.56,
      "end": 70.36,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 70.48,
      "end": 73.9,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să vedem puțin umărul. Stați așa, relaxat."
    },
    {
      "start": 74.02,
      "end": 75.16,
      "speaker": "SPEAKER_00",
      "text": "Apăs aici, doare?"
    },
    {
      "start": 75.28,
      "end": 76.42,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo doare."
    },
    {
      "start": 76.54,
      "end": 81.48,
      "speaker": "SPEAKER_00",
      "text": "Pe zona asta de sus a umărului. Și dacă apăs mai spre față?"
    },
    {
      "start": 81.6,
      "end": 82.4,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 82.52,
      "end": 86.7,
      "speaker": "SPEAKER_00",
      "text": "Am înțeles. Ridicați mâna din nou în lateral pentru mine, ușor."
    },
    {
      "start": 86.82,
      "end": 87.62,
      "speaker": "SPEAKER_01",
      "text": "Au."
    },
    {
      "start": 87.74,
      "end": 91.54,
      "speaker": "SPEAKER_00",
      "text": "Doare exact la 90 de grade, după aceea mai puțin?"
    },
    {
      "start": 91.66,
      "end": 92.46,
      "speaker": "SPEAKER_01",
      "text": "Da, exact."
    },
    {
      "start": 92.58,
      "end": 106.26,
      "speaker": "SPEAKER_00",
      "text": "Ăsta e un semn specific. Avem o inflamație la nivelul tendonului de supraspinat. Se numește tendinită de supraspinat, posibil și un conflict subacomial. Asta apare de obicei după un efort brusc, cum a fost cu mobila."
    },
    {
      "start": 106.38,
      "end": 111.32,
      "speaker": "SPEAKER_00",
      "text": "O să lucrăm să reducem inflamația și să redăm mobilitatea completă a umărului."
    },
    {
      "start": 111.44,
      "end": 112.24,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 112.36,
      "end": 114.26,
      "speaker": "SPEAKER_00",
      "text": "Haideți pe masă, vă rog."
    }
  ]
}
