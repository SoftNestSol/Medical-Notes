  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua."
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 4.12,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem azi?"
    },
    {
      "start": 4.24,
      "end": 5.38,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 5.5,
      "end": 7.02,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De cât timp?"
    },
    {
      "start": 7.14,
      "end": 8.28,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 8.4,
      "end": 10.68,
      "speaker": "SPEAKER_00",
      "text": "Și a apărut brusc sau treptat?"
    },
    {
      "start": 10.8,
      "end": 15.36,
      "speaker": "SPEAKER_01",
      "text": "Brusc. M-am trezit dimineața și nu mai puteam să întorc capul."
    },
    {
      "start": 15.48,
      "end": 24.6,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, cât de tare doare acum?"
    },
    {
      "start": 24.72,
      "end": 25.52,
      "speaker": "SPEAKER_01",
      "text": "Vreo 5."
    },
    {
      "start": 25.64,
      "end": 27.54,
      "speaker": "SPEAKER_00",
      "text": "5. Și la mișcare, crește?"
    },
    {
      "start": 27.66,
      "end": 28.8,
      "speaker": "SPEAKER_01",
      "text": "Da, mai rău."
    },
    {
      "start": 28.92,
      "end": 32.34,
      "speaker": "SPEAKER_00",
      "text": "Doare și în umăr sau se lasă pe braț?"
    },
    {
      "start": 32.46,
      "end": 33.98,
      "speaker": "SPEAKER_01",
      "text": "Puțin în umărul drept."
    },
    {
      "start": 34.1,
      "end": 36.0,
      "speaker": "SPEAKER_00",
      "text": "Umărul drept. Amorțește mâna dreaptă?"
    },
    {
      "start": 36.12,
      "end": 36.92,
      "speaker": "SPEAKER_01",
      "text": "Uneori."
    },
    {
      "start": 37.04,
      "end": 38.56,
      "speaker": "SPEAKER_00",
      "text": "Uneori. Când, mai ales?"
    },
    {
      "start": 38.68,
      "end": 40.2,
      "speaker": "SPEAKER_01",
      "text": "Dimineața când mă trezesc."
    },
    {
      "start": 40.32,
      "end": 42.22,
      "speaker": "SPEAKER_00",
      "text": "Ok. Dureri de cap, amețeli?"
    },
    {
      "start": 42.34,
      "end": 43.14,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 43.26,
      "end": 45.54,
      "speaker": "SPEAKER_00",
      "text": "Alte zone dor? Spatele, de exemplu?"
    },
    {
      "start": 45.66,
      "end": 46.8,
      "speaker": "SPEAKER_01",
      "text": "Nu, numai gâtul."
    },
    {
      "start": 46.92,
      "end": 49.96,
      "speaker": "SPEAKER_00",
      "text": "Bun. Lucrați la birou, stați mult pe calculator?"
    },
    {
      "start": 50.08,
      "end": 51.22,
      "speaker": "SPEAKER_01",
      "text": "Da, toată ziua."
    },
    {
      "start": 51.34,
      "end": 55.14,
      "speaker": "SPEAKER_00",
      "text": "Toată ziua la calculator. Înțeles. Alte afecțiuni, tensiune, diabet, osteoporoză?"
    },
    {
      "start": 55.26,
      "end": 56.4,
      "speaker": "SPEAKER_01",
      "text": "Tensiune am, da."
    },
    {
      "start": 56.52,
      "end": 58.8,
      "speaker": "SPEAKER_00",
      "text": "Tensiune arterială. Luați ceva pentru ea?"
    },
    {
      "start": 58.92,
      "end": 59.72,
      "speaker": "SPEAKER_01",
      "text": "Prestarium."
    },
    {
      "start": 59.84,
      "end": 61.36,
      "speaker": "SPEAKER_00",
      "text": "Prestarium. Știți ce doză?"
    },
    {
      "start": 61.48,
      "end": 63.38,
      "speaker": "SPEAKER_01",
      "text": "Nu știu exact. 5, parcă."
    },
    {
      "start": 63.5,
      "end": 65.02,
      "speaker": "SPEAKER_00",
      "text": "Ok. Altceva mai luați?"
    },
    {
      "start": 65.14,
      "end": 65.94,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 66.06,
      "end": 68.34,
      "speaker": "SPEAKER_00",
      "text": "Ați mai făcut terapie pentru gât?"
    },
    {
      "start": 68.46,
      "end": 69.26,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 69.38,
      "end": 73.94,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să stați în picioare, cu spatele la mine. Relaxați umerii."
    },
    {
      "start": 74.06,
      "end": 74.86,
      "speaker": "SPEAKER_01",
      "text": "Bine."
    },
    {
      "start": 74.98,
      "end": 80.68,
      "speaker": "SPEAKER_00",
      "text": "Vedeți că aveți umărul drept mai ridicat decât stângul. Simțiți tensiune aici, în zona asta?"
    },
    {
      "start": 80.8,
      "end": 81.6,
      "speaker": "SPEAKER_01",
      "text": "Da, mereu."
    },
    {
      "start": 81.72,
      "end": 83.62,
      "speaker": "SPEAKER_00",
      "text": "Întoarceți capul spre dreapta, încet."
    },
    {
      "start": 83.74,
      "end": 85.64,
      "speaker": "SPEAKER_01",
      "text": "Până aici, nu mai pot."
    },
    {
      "start": 85.76,
      "end": 89.18,
      "speaker": "SPEAKER_00",
      "text": "Da, văd, e limitată rotația spre dreapta. Doare acum?"
    },
    {
      "start": 89.3,
      "end": 90.1,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 90.22,
      "end": 92.12,
      "speaker": "SPEAKER_00",
      "text": "Spre stânga merge mai bine?"
    },
    {
      "start": 92.24,
      "end": 93.38,
      "speaker": "SPEAKER_01",
      "text": "Un pic da."
    },
    {
      "start": 93.5,
      "end": 98.44,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Apăs acum pe mușchii de lângă coloana cervicală. Spuneți-mi dacă doare."
    },
    {
      "start": 98.56,
      "end": 99.36,
      "speaker": "SPEAKER_01",
      "text": "Doare, da."
    },
    {
      "start": 99.48,
      "end": 101.0,
      "speaker": "SPEAKER_00",
      "text": "Și pe trapez, aici?"
    },
    {
      "start": 101.12,
      "end": 101.92,
      "speaker": "SPEAKER_01",
      "text": "Și acolo."
    },
    {
      "start": 102.04,
      "end": 121.04,
      "speaker": "SPEAKER_00",
      "text": "Bun. Deci avem o contractură musculară cervicală cu limitare de mobilitate, mai ales spre dreapta. Cel mai probabil legată de postura la calculator. O să lucrăm să reducem contractura și să redobândiți mobilitatea. Putem face câteva ședințe de terapie manuală și o să vă arăt și niște exerciții pentru acasă."
    },
    {
      "start": 121.16,
      "end": 121.96,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 122.08,
      "end": 123.22,
      "speaker": "SPEAKER_00",
      "text": "Haideți pe masă."
    }
  ]
}
