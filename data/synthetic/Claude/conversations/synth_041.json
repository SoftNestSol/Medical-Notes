{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.14,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule."
    },
    {
      "start": 1.26,
      "end": 2.06,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.18,
      "end": 4.46,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi și numele, vă rog."
    },
    {
      "start": 4.58,
      "end": 5.38,
      "speaker": "SPEAKER_01",
      "text": "Gheorghe Nistor."
    },
    {
      "start": 5.5,
      "end": 7.4,
      "speaker": "SPEAKER_00",
      "text": "Mulțumesc, domnule Nistor. Și vârsta?"
    },
    {
      "start": 7.52,
      "end": 8.32,
      "speaker": "SPEAKER_01",
      "text": "51."
    },
    {
      "start": 8.44,
      "end": 10.72,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem astăzi?"
    },
    {
      "start": 10.84,
      "end": 11.98,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 12.1,
      "end": 13.62,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De cât timp?"
    },
    {
      "start": 13.74,
      "end": 15.26,
      "speaker": "SPEAKER_01",
      "text": "De vreo două săptămâni."
    },
    {
      "start": 15.38,
      "end": 18.8,
      "speaker": "SPEAKER_00",
      "text": "Și a apărut din senin sau după ceva anume?"
    },
    {
      "start": 18.92,
      "end": 23.1,
      "speaker": "SPEAKER_01",
      "text": "Păi... nu știu exact. M-am trezit dimineața și era acolo."
    },
    {
      "start": 23.22,
      "end": 30.44,
      "speaker": "SPEAKER_00",
      "text": "Dimineața v-ați trezit cu durerea. Înțeles. Doare doar în gât sau se lasă și pe umăr, pe braț?"
    },
    {
      "start": 30.56,
      "end": 31.7,
      "speaker": "SPEAKER_01",
      "text": "Și pe umăr."
    },
    {
      "start": 31.82,
      "end": 32.96,
      "speaker": "SPEAKER_00",
      "text": "Pe care umăr?"
    },
    {
      "start": 33.08,
      "end": 33.88,
      "speaker": "SPEAKER_01",
      "text": "Pe dreapta."
    },
    {
      "start": 34.0,
      "end": 37.8,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul drept. Și pe braț mai jos se lasă?"
    },
    {
      "start": 37.92,
      "end": 38.72,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 38.84,
      "end": 47.58,
      "speaker": "SPEAKER_00",
      "text": "Nu. Bun. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, unde vă situați?"
    },
    {
      "start": 47.7,
      "end": 48.5,
      "speaker": "SPEAKER_01",
      "text": "Un 6."
    },
    {
      "start": 48.62,
      "end": 53.18,
      "speaker": "SPEAKER_00",
      "text": "Un 6. Doare mai tare când întoarceți capul sau când stați liniștit?"
    },
    {
      "start": 53.3,
      "end": 54.1,
      "speaker": "SPEAKER_01",
      "text": "Când întorc."
    },
    {
      "start": 54.22,
      "end": 56.12,
      "speaker": "SPEAKER_00",
      "text": "Spre dreapta sau spre stânga?"
    },
    {
      "start": 56.24,
      "end": 57.76,
      "speaker": "SPEAKER_01",
      "text": "Spre dreapta mai rău."
    },
    {
      "start": 57.88,
      "end": 60.54,
      "speaker": "SPEAKER_00",
      "text": "Spre dreapta. Și noaptea vă trezește durerea?"
    },
    {
      "start": 60.66,
      "end": 61.46,
      "speaker": "SPEAKER_01",
      "text": "Câteodată."
    },
    {
      "start": 61.58,
      "end": 64.62,
      "speaker": "SPEAKER_00",
      "text": "Câteodată. Ce muncă faceți, dacă pot să întreb?"
    },
    {
      "start": 64.74,
      "end": 66.26,
      "speaker": "SPEAKER_01",
      "text": "Stau mult la calculator."
    },
    {
      "start": 66.38,
      "end": 71.32,
      "speaker": "SPEAKER_00",
      "text": "Mult la calculator, înțeles. Alte afecțiuni aveți, tensiune, diabet, ceva la coloană diagnosticat?"
    },
    {
      "start": 71.44,
      "end": 72.24,
      "speaker": "SPEAKER_01",
      "text": "Tensiune am."
    },
    {
      "start": 72.36,
      "end": 74.64,
      "speaker": "SPEAKER_00",
      "text": "Tensiune arterială. Luați ceva pentru ea?"
    },
    {
      "start": 74.76,
      "end": 75.56,
      "speaker": "SPEAKER_01",
      "text": "Da, Prenessa."
    },
    {
      "start": 75.68,
      "end": 77.2,
      "speaker": "SPEAKER_00",
      "text": "Prenessa. Știți ce doză?"
    },
    {
      "start": 77.32,
      "end": 78.46,
      "speaker": "SPEAKER_01",
      "text": "4 miligrame, cred."
    },
    {
      "start": 78.58,
      "end": 80.48,
      "speaker": "SPEAKER_00",
      "text": "4 miligrame. Altceva mai luați?"
    },
    {
      "start": 80.6,
      "end": 81.4,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 81.52,
      "end": 83.8,
      "speaker": "SPEAKER_00",
      "text": "Nicio altă afecțiune, diabet, epilepsie, osteoporoză?"
    },
    {
      "start": 83.92,
      "end": 84.72,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 84.84,
      "end": 85.64,
      "speaker": "SPEAKER_00",
      "text": "Operații anterioare?"
    },
    {
      "start": 85.76,
      "end": 86.56,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 86.68,
      "end": 88.2,
      "speaker": "SPEAKER_00",
      "text": "Alergii la creme, unguiente?"
    },
    {
      "start": 88.32,
      "end": 89.12,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 89.24,
      "end": 96.08,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să vă ridic puțin în picioare și fac câteva mișcări, da? Întoarceți capul ușor spre dreapta."
    },
    {
      "start": 96.2,
      "end": 97.0,
      "speaker": "SPEAKER_01",
      "text": "Ah."
    },
    {
      "start": 97.12,
      "end": 97.92,
      "speaker": "SPEAKER_00",
      "text": "Doare?"
    },
    {
      "start": 98.04,
      "end": 98.84,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 98.96,
      "end": 100.1,
      "speaker": "SPEAKER_00",
      "text": "Și spre stânga?"
    },
    {
      "start": 100.22,
      "end": 101.02,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 101.14,
      "end": 106.08,
      "speaker": "SPEAKER_00",
      "text": "Mai puțin, bine. Apăs puțin aici pe zona cervicală, îmi spuneți dacă doare."
    },
    {
      "start": 106.2,
      "end": 107.0,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo."
    },
    {
      "start": 107.12,
      "end": 109.78,
      "speaker": "SPEAKER_00",
      "text": "Da, exact. Și pe trapez, pe dreapta?"
    },
    {
      "start": 109.9,
      "end": 111.04,
      "speaker": "SPEAKER_01",
      "text": "Da, și acolo."
    },
    {
      "start": 111.16,
      "end": 125.22,
      "speaker": "SPEAKER_00",
      "text": "Bun. Deci avem o contractură pe zona cervicală și pe trapezul drept, cel mai probabil de la postura la calculator. O să lucrăm să reducem contractura și să refacem mobilitatea pe cervical. Hai să trecem la masă."
    }
  ]
}
