{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.14,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule."
    },
    {
      "start": 1.26,
      "end": 2.06,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.18,
      "end": 4.84,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi și mie numele, vă rog."
    },
    {
      "start": 4.96,
      "end": 5.76,
      "speaker": "SPEAKER_01",
      "text": "Gheorghe Nan."
    },
    {
      "start": 5.88,
      "end": 6.68,
      "speaker": "SPEAKER_00",
      "text": "Și vârsta?"
    },
    {
      "start": 6.8,
      "end": 7.6,
      "speaker": "SPEAKER_01",
      "text": "48."
    },
    {
      "start": 7.72,
      "end": 10.0,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem azi?"
    },
    {
      "start": 10.12,
      "end": 11.26,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 11.38,
      "end": 12.52,
      "speaker": "SPEAKER_00",
      "text": "De cât timp?"
    },
    {
      "start": 12.64,
      "end": 13.78,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 13.9,
      "end": 16.18,
      "speaker": "SPEAKER_00",
      "text": "Și a apărut brusc sau treptat?"
    },
    {
      "start": 16.3,
      "end": 20.48,
      "speaker": "SPEAKER_01",
      "text": "Brusc, dimineața m-am trezit și nu mai puteam întoarce capul."
    },
    {
      "start": 20.6,
      "end": 25.54,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Doare doar în gât sau se lasă și pe umăr, pe braț?"
    },
    {
      "start": 25.66,
      "end": 27.56,
      "speaker": "SPEAKER_01",
      "text": "Și pe umăr. Cel drept."
    },
    {
      "start": 27.68,
      "end": 29.58,
      "speaker": "SPEAKER_00",
      "text": "Pe braț în jos doare?"
    },
    {
      "start": 29.7,
      "end": 30.5,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 30.62,
      "end": 32.52,
      "speaker": "SPEAKER_00",
      "text": "Amorțeli în mână, în degete?"
    },
    {
      "start": 32.64,
      "end": 33.44,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 33.56,
      "end": 41.16,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare maxim, cât ați da?"
    },
    {
      "start": 41.28,
      "end": 42.08,
      "speaker": "SPEAKER_01",
      "text": "Un 6."
    },
    {
      "start": 42.2,
      "end": 44.48,
      "speaker": "SPEAKER_00",
      "text": "Un 6. E constant sau variază?"
    },
    {
      "start": 44.6,
      "end": 46.5,
      "speaker": "SPEAKER_01",
      "text": "Variază. Dimineața e mai rău."
    },
    {
      "start": 46.62,
      "end": 47.76,
      "speaker": "SPEAKER_00",
      "text": "Lucrați la birou?"
    },
    {
      "start": 47.88,
      "end": 48.68,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 48.8,
      "end": 50.32,
      "speaker": "SPEAKER_00",
      "text": "Mult timp la calculator?"
    },
    {
      "start": 50.44,
      "end": 51.58,
      "speaker": "SPEAKER_01",
      "text": "Da, toată ziua."
    },
    {
      "start": 51.7,
      "end": 54.74,
      "speaker": "SPEAKER_00",
      "text": "Bun. Alte afecțiuni mai aveți? Tensiune, diabet, ceva?"
    },
    {
      "start": 54.86,
      "end": 55.66,
      "speaker": "SPEAKER_01",
      "text": "Am tensiune."
    },
    {
      "start": 55.78,
      "end": 56.58,
      "speaker": "SPEAKER_00",
      "text": "Hipertensiune arterială?"
    },
    {
      "start": 56.7,
      "end": 57.5,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 57.62,
      "end": 59.14,
      "speaker": "SPEAKER_00",
      "text": "Luați ceva pentru tensiune?"
    },
    {
      "start": 59.26,
      "end": 60.06,
      "speaker": "SPEAKER_01",
      "text": "Da, Enalapril."
    },
    {
      "start": 60.18,
      "end": 60.98,
      "speaker": "SPEAKER_00",
      "text": "Ce doză?"
    },
    {
      "start": 61.1,
      "end": 61.9,
      "speaker": "SPEAKER_01",
      "text": "10 miligrame."
    },
    {
      "start": 62.02,
      "end": 62.82,
      "speaker": "SPEAKER_00",
      "text": "Zilnic?"
    },
    {
      "start": 62.94,
      "end": 63.74,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 63.86,
      "end": 65.0,
      "speaker": "SPEAKER_00",
      "text": "Altceva mai luați?"
    },
    {
      "start": 65.12,
      "end": 65.92,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 66.04,
      "end": 67.18,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale, accidente?"
    },
    {
      "start": 67.3,
      "end": 68.1,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 68.22,
      "end": 69.36,
      "speaker": "SPEAKER_00",
      "text": "Stimulator cardiac, implanturi?"
    },
    {
      "start": 69.48,
      "end": 70.28,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 70.4,
      "end": 75.34,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să stați puțin în picioare, îmi spuneți dacă doare când apăs."
    },
    {
      "start": 75.46,
      "end": 76.26,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 76.38,
      "end": 81.32,
      "speaker": "SPEAKER_00",
      "text": "Apăs acum pe zona cervicală, pe mușchii de aici de la ceafă. Doare?"
    },
    {
      "start": 81.44,
      "end": 82.24,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 82.36,
      "end": 83.16,
      "speaker": "SPEAKER_00",
      "text": "Tare?"
    },
    {
      "start": 83.28,
      "end": 84.8,
      "speaker": "SPEAKER_01",
      "text": "Da, destul de tare."
    },
    {
      "start": 84.92,
      "end": 87.96,
      "speaker": "SPEAKER_00",
      "text": "Pe trapez, pe umărul drept, apăs aici. Doare?"
    },
    {
      "start": 88.08,
      "end": 89.22,
      "speaker": "SPEAKER_01",
      "text": "Da, și acolo."
    },
    {
      "start": 89.34,
      "end": 91.24,
      "speaker": "SPEAKER_00",
      "text": "Întoarceți capul ușor spre dreapta."
    },
    {
      "start": 91.36,
      "end": 92.88,
      "speaker": "SPEAKER_01",
      "text": "Mă doare dacă întorc."
    },
    {
      "start": 93.0,
      "end": 94.9,
      "speaker": "SPEAKER_00",
      "text": "Cât de mult puteți întoarce?"
    },
    {
      "start": 95.02,
      "end": 96.54,
      "speaker": "SPEAKER_01",
      "text": "Pe jumătate, cam așa."
    },
    {
      "start": 96.66,
      "end": 97.8,
      "speaker": "SPEAKER_00",
      "text": "Și spre stânga?"
    },
    {
      "start": 97.92,
      "end": 99.06,
      "speaker": "SPEAKER_01",
      "text": "Ceva mai bine."
    },
    {
      "start": 99.18,
      "end": 101.08,
      "speaker": "SPEAKER_00",
      "text": "Dați capul puțin pe spate."
    },
    {
      "start": 101.2,
      "end": 102.34,
      "speaker": "SPEAKER_01",
      "text": "Nu prea pot."
    },
    {
      "start": 102.46,
      "end": 103.26,
      "speaker": "SPEAKER_00",
      "text": "Doare?"
    },
    {
      "start": 103.38,
      "end": 104.18,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 104.3,
      "end": 125.58,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Deci avem o contractură pe zona cervicală și pe trapezul drept, mobilitatea e redusă în rotație dreapta și în extensie. Vom lucra să reducem tensiunea musculară și să recuperăm mobilitatea. Ce vă pot spune acum este că e o problemă de postură legată de statul la birou, cel mai probabil. Haideți pe masă, vă rog."
    }
  ]
}
