{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.14,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule."
    },
    {
      "start": 1.26,
      "end": 2.06,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.18,
      "end": 4.08,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi numele, vă rog."
    },
    {
      "start": 4.2,
      "end": 5.0,
      "speaker": "SPEAKER_01",
      "text": "Gheorghe Marin."
    },
    {
      "start": 5.12,
      "end": 5.92,
      "speaker": "SPEAKER_00",
      "text": "Vârsta?"
    },
    {
      "start": 6.04,
      "end": 6.84,
      "speaker": "SPEAKER_01",
      "text": "48."
    },
    {
      "start": 6.96,
      "end": 10.0,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem astăzi, domnule Marin?"
    },
    {
      "start": 10.12,
      "end": 11.26,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 11.38,
      "end": 12.52,
      "speaker": "SPEAKER_00",
      "text": "De cât timp?"
    },
    {
      "start": 12.64,
      "end": 13.78,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 13.9,
      "end": 18.08,
      "speaker": "SPEAKER_00",
      "text": "S-a întâmplat ceva anume, v-ați lovit, ați dormit prost?"
    },
    {
      "start": 18.2,
      "end": 21.24,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, m-am trezit și mă durea."
    },
    {
      "start": 21.36,
      "end": 23.26,
      "speaker": "SPEAKER_00",
      "text": "Deci a apărut brusc, dimineața."
    },
    {
      "start": 23.38,
      "end": 24.18,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 24.3,
      "end": 28.48,
      "speaker": "SPEAKER_00",
      "text": "Doare doar gâtul sau se lasă și pe umăr, pe braț?"
    },
    {
      "start": 28.6,
      "end": 30.12,
      "speaker": "SPEAKER_01",
      "text": "Și pe umărul drept."
    },
    {
      "start": 30.24,
      "end": 34.04,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul drept. Se lasă și pe braț în jos?"
    },
    {
      "start": 34.16,
      "end": 35.3,
      "speaker": "SPEAKER_01",
      "text": "Nu, nu chiar."
    },
    {
      "start": 35.42,
      "end": 36.56,
      "speaker": "SPEAKER_00",
      "text": "Amorțeli în mână?"
    },
    {
      "start": 36.68,
      "end": 37.48,
      "speaker": "SPEAKER_01",
      "text": "Câteodată."
    },
    {
      "start": 37.6,
      "end": 39.12,
      "speaker": "SPEAKER_00",
      "text": "Câteodată. Pe ce degete?"
    },
    {
      "start": 39.24,
      "end": 41.14,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, pe toate parcă."
    },
    {
      "start": 41.26,
      "end": 49.24,
      "speaker": "SPEAKER_00",
      "text": "Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte tare, unde vă situați?"
    },
    {
      "start": 49.36,
      "end": 50.16,
      "speaker": "SPEAKER_01",
      "text": "Vreo 6."
    },
    {
      "start": 50.28,
      "end": 54.84,
      "speaker": "SPEAKER_00",
      "text": "6. Doare mai tare când vă întoarceți capul sau când stați nemișcat?"
    },
    {
      "start": 54.96,
      "end": 56.1,
      "speaker": "SPEAKER_01",
      "text": "Când mă întorc."
    },
    {
      "start": 56.22,
      "end": 58.12,
      "speaker": "SPEAKER_00",
      "text": "Spre dreapta sau spre stânga?"
    },
    {
      "start": 58.24,
      "end": 59.76,
      "speaker": "SPEAKER_01",
      "text": "Mai mult spre dreapta."
    },
    {
      "start": 59.88,
      "end": 62.92,
      "speaker": "SPEAKER_00",
      "text": "Bun. Ce lucru faceți, stați mult la birou?"
    },
    {
      "start": 63.04,
      "end": 64.18,
      "speaker": "SPEAKER_01",
      "text": "Da, toată ziua."
    },
    {
      "start": 64.3,
      "end": 65.82,
      "speaker": "SPEAKER_00",
      "text": "Toată ziua la calculator."
    },
    {
      "start": 65.94,
      "end": 66.74,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 66.86,
      "end": 69.52,
      "speaker": "SPEAKER_00",
      "text": "Alte afecțiuni aveți, tensiune, diabet, osteoporoză, epilepsie?"
    },
    {
      "start": 69.64,
      "end": 70.44,
      "speaker": "SPEAKER_01",
      "text": "Tensiune am."
    },
    {
      "start": 70.56,
      "end": 72.84,
      "speaker": "SPEAKER_00",
      "text": "Tensiune arterială. Luați ceva pentru ea?"
    },
    {
      "start": 72.96,
      "end": 73.76,
      "speaker": "SPEAKER_01",
      "text": "Da, Enalapril."
    },
    {
      "start": 73.88,
      "end": 74.68,
      "speaker": "SPEAKER_00",
      "text": "Ce doză?"
    },
    {
      "start": 74.8,
      "end": 75.6,
      "speaker": "SPEAKER_01",
      "text": "10 miligrame."
    },
    {
      "start": 75.72,
      "end": 78.0,
      "speaker": "SPEAKER_00",
      "text": "10 miligrame, o dată pe zi?"
    },
    {
      "start": 78.12,
      "end": 78.92,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 79.04,
      "end": 80.18,
      "speaker": "SPEAKER_00",
      "text": "Altceva mai luați?"
    },
    {
      "start": 80.3,
      "end": 81.1,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 81.22,
      "end": 82.36,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale, fracturi?"
    },
    {
      "start": 82.48,
      "end": 83.28,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 83.4,
      "end": 84.92,
      "speaker": "SPEAKER_00",
      "text": "Alergii la creme, unguiente?"
    },
    {
      "start": 85.04,
      "end": 85.84,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 85.96,
      "end": 91.28,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să fac câteva teste. Puneți-vă în picioare un moment, vă rog."
    },
    {
      "start": 91.4,
      "end": 92.2,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 92.32,
      "end": 94.6,
      "speaker": "SPEAKER_00",
      "text": "Întoarceți capul ușor spre dreapta... doare?"
    },
    {
      "start": 94.72,
      "end": 95.52,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 95.64,
      "end": 96.44,
      "speaker": "SPEAKER_00",
      "text": "Spre stânga?"
    },
    {
      "start": 96.56,
      "end": 97.36,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 97.48,
      "end": 99.38,
      "speaker": "SPEAKER_00",
      "text": "Aplecați capul spre umărul drept."
    },
    {
      "start": 99.5,
      "end": 100.3,
      "speaker": "SPEAKER_01",
      "text": "Au, da."
    },
    {
      "start": 100.42,
      "end": 103.08,
      "speaker": "SPEAKER_00",
      "text": "Doare pe partea dreaptă a gâtului, da?"
    },
    {
      "start": 103.2,
      "end": 104.0,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 104.12,
      "end": 108.3,
      "speaker": "SPEAKER_00",
      "text": "Apăs puțin aici pe musculatura cervicală dreaptă, spuneți-mi dacă doare."
    },
    {
      "start": 108.42,
      "end": 109.22,
      "speaker": "SPEAKER_01",
      "text": "Da, doare."
    },
    {
      "start": 109.34,
      "end": 110.86,
      "speaker": "SPEAKER_00",
      "text": "Și aici pe trapez?"
    },
    {
      "start": 110.98,
      "end": 112.12,
      "speaker": "SPEAKER_01",
      "text": "Da, și acolo."
    },
    {
      "start": 112.24,
      "end": 133.52,
      "speaker": "SPEAKER_00",
      "text": "Bun. Ce vă pot spune este că avem o contractură musculară destul de serioasă pe zona cervicală și trapez pe partea dreaptă. Mobilitatea rotației spre dreapta e redusă. O să lucrăm să reducem contractura și să recâștigăm mobilitatea. Fără imagistică deocamdată, dacă nu se ameliorează în câteva ședințe, o să vă recomand să faceți o radiografie."
    },
    {
      "start": 133.64,
      "end": 134.44,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 134.56,
      "end": 136.84,
      "speaker": "SPEAKER_00",
      "text": "Haideți să ne așezăm pe masă."
    }
  ]
}
