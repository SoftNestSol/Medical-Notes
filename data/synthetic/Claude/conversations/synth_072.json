{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 0.8,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua!"
    },
    {
      "start": 0.92,
      "end": 1.72,
      "speaker": "SPEAKER_01",
      "text": "Bună."
    },
    {
      "start": 1.84,
      "end": 3.36,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă veniți?"
    },
    {
      "start": 3.48,
      "end": 4.62,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 4.74,
      "end": 5.54,
      "speaker": "SPEAKER_00",
      "text": "De când?"
    },
    {
      "start": 5.66,
      "end": 6.8,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 6.92,
      "end": 9.96,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. Și a apărut brusc sau treptat?"
    },
    {
      "start": 10.08,
      "end": 11.6,
      "speaker": "SPEAKER_01",
      "text": "Nu știu. Treptat, cred."
    },
    {
      "start": 11.72,
      "end": 14.38,
      "speaker": "SPEAKER_00",
      "text": "Aveți o muncă la birou, la calculator?"
    },
    {
      "start": 14.5,
      "end": 15.3,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 15.42,
      "end": 16.94,
      "speaker": "SPEAKER_00",
      "text": "Multe ore pe zi?"
    },
    {
      "start": 17.06,
      "end": 18.58,
      "speaker": "SPEAKER_01",
      "text": "Vreo opt, nouă ore."
    },
    {
      "start": 18.7,
      "end": 24.4,
      "speaker": "SPEAKER_00",
      "text": "Înțeleg. Durerea rămâne doar în zona gâtului sau se lasă și pe braț, pe umăr?"
    },
    {
      "start": 24.52,
      "end": 26.42,
      "speaker": "SPEAKER_01",
      "text": "Și pe umăr. Pe stânga."
    },
    {
      "start": 26.54,
      "end": 30.72,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul stâng. Până unde se lasă, mai jos de umăr?"
    },
    {
      "start": 30.84,
      "end": 31.98,
      "speaker": "SPEAKER_01",
      "text": "Nu. Doar umărul."
    },
    {
      "start": 32.1,
      "end": 35.52,
      "speaker": "SPEAKER_00",
      "text": "Doar umărul, ok. Amorțeli în mână stângă, în degete?"
    },
    {
      "start": 35.64,
      "end": 36.44,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 36.56,
      "end": 44.92,
      "speaker": "SPEAKER_00",
      "text": "Bun. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, unde situați durerea?"
    },
    {
      "start": 45.04,
      "end": 45.84,
      "speaker": "SPEAKER_01",
      "text": "Un 5."
    },
    {
      "start": 45.96,
      "end": 48.62,
      "speaker": "SPEAKER_00",
      "text": "5. E mai rău dimineața sau seara?"
    },
    {
      "start": 48.74,
      "end": 49.54,
      "speaker": "SPEAKER_01",
      "text": "Seara."
    },
    {
      "start": 49.66,
      "end": 52.7,
      "speaker": "SPEAKER_00",
      "text": "Seara, după ce ați stat mult la calculator."
    },
    {
      "start": 52.82,
      "end": 53.62,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 53.74,
      "end": 56.78,
      "speaker": "SPEAKER_00",
      "text": "Aveți și dureri de cap legate de asta?"
    },
    {
      "start": 56.9,
      "end": 57.7,
      "speaker": "SPEAKER_01",
      "text": "Câteodată."
    },
    {
      "start": 57.82,
      "end": 58.62,
      "speaker": "SPEAKER_00",
      "text": "Amețeli?"
    },
    {
      "start": 58.74,
      "end": 59.54,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 59.66,
      "end": 63.46,
      "speaker": "SPEAKER_00",
      "text": "Bun. Alte afecțiuni, tensiune, diabet, osteoporoză, hernie de disc diagnosticată?"
    },
    {
      "start": 63.58,
      "end": 66.24,
      "speaker": "SPEAKER_01",
      "text": "Nu știu de hernie. Tensiune am, da."
    },
    {
      "start": 66.36,
      "end": 69.02,
      "speaker": "SPEAKER_00",
      "text": "Tensiune arterială crescută. Luați medicamente pentru asta?"
    },
    {
      "start": 69.14,
      "end": 69.94,
      "speaker": "SPEAKER_01",
      "text": "Da, Enalapril."
    },
    {
      "start": 70.06,
      "end": 70.86,
      "speaker": "SPEAKER_00",
      "text": "Ce doză?"
    },
    {
      "start": 70.98,
      "end": 71.78,
      "speaker": "SPEAKER_01",
      "text": "10 miligrame."
    },
    {
      "start": 71.9,
      "end": 72.7,
      "speaker": "SPEAKER_00",
      "text": "Luați zilnic?"
    },
    {
      "start": 72.82,
      "end": 73.62,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 73.74,
      "end": 74.88,
      "speaker": "SPEAKER_00",
      "text": "Altceva mai luați?"
    },
    {
      "start": 75.0,
      "end": 75.8,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 75.92,
      "end": 77.44,
      "speaker": "SPEAKER_00",
      "text": "Ok. Alergii la medicamente?"
    },
    {
      "start": 77.56,
      "end": 78.36,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 78.48,
      "end": 81.14,
      "speaker": "SPEAKER_00",
      "text": "Ați mai făcut vreodată terapie manuală, kinetoterapie?"
    },
    {
      "start": 81.26,
      "end": 82.06,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 82.18,
      "end": 87.88,
      "speaker": "SPEAKER_00",
      "text": "Prima oară. Bun. Haideți să facem câteva teste rapide. Întoarceți capul spre dreapta, încet. Doare?"
    },
    {
      "start": 88.0,
      "end": 88.8,
      "speaker": "SPEAKER_01",
      "text": "Un pic."
    },
    {
      "start": 88.92,
      "end": 89.72,
      "speaker": "SPEAKER_00",
      "text": "Spre stânga."
    },
    {
      "start": 89.84,
      "end": 91.36,
      "speaker": "SPEAKER_01",
      "text": "Aia doare mai tare."
    },
    {
      "start": 91.48,
      "end": 96.04,
      "speaker": "SPEAKER_00",
      "text": "Da, limitare și durere la rotație stânga. Lăsați capul pe umărul stâng."
    },
    {
      "start": 96.16,
      "end": 96.96,
      "speaker": "SPEAKER_01",
      "text": "Au."
    },
    {
      "start": 97.08,
      "end": 98.6,
      "speaker": "SPEAKER_00",
      "text": "Doare. Pe umărul drept?"
    },
    {
      "start": 98.72,
      "end": 99.52,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 99.64,
      "end": 104.2,
      "speaker": "SPEAKER_00",
      "text": "Înțeleg. Apăs acum pe mușchii de la ceafă, îmi spuneți dacă doare."
    },
    {
      "start": 104.32,
      "end": 105.46,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo doare."
    },
    {
      "start": 105.58,
      "end": 124.96,
      "speaker": "SPEAKER_00",
      "text": "Contractură bună pe trapez și pe ridicătorul scapulei, mai ales pe stânga. Vedem o postură cu capul dus înainte, ceea ce pune presiune suplimentară pe cervical. Eu zic să începem cu relaxarea musculaturii cervicale și a trapezelui, să recuperăm mobilitatea, și în câteva ședințe ar trebui să vă simțiți mai bine."
    },
    {
      "start": 125.08,
      "end": 125.88,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 126.0,
      "end": 128.66,
      "speaker": "SPEAKER_00",
      "text": "Vă rugăm să vă așezați pe masă."
    }
  ]
}
