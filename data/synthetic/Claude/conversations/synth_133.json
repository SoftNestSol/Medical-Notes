{
  "audio_path": null,
  "language": "ro",
  "model": "claude-sonnet-4-6",
  "segments": [
    {
      "start": 0.0,
      "end": 1.52,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule Radu."
    },
    {
      "start": 1.64,
      "end": 2.44,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.56,
      "end": 4.84,
      "speaker": "SPEAKER_00",
      "text": "Cu ce problemă ne vedem astăzi?"
    },
    {
      "start": 4.96,
      "end": 6.1,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 6.22,
      "end": 7.74,
      "speaker": "SPEAKER_00",
      "text": "Gâtul. De câte zile?"
    },
    {
      "start": 7.86,
      "end": 9.0,
      "speaker": "SPEAKER_01",
      "text": "Vreo două săptămâni."
    },
    {
      "start": 9.12,
      "end": 13.3,
      "speaker": "SPEAKER_00",
      "text": "Două săptămâni. Și a apărut din senin sau după ceva anume?"
    },
    {
      "start": 13.42,
      "end": 15.7,
      "speaker": "SPEAKER_01",
      "text": "Nu știu, probabil de la calculator."
    },
    {
      "start": 15.82,
      "end": 17.34,
      "speaker": "SPEAKER_00",
      "text": "Stați mult la birou?"
    },
    {
      "start": 17.46,
      "end": 18.26,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 18.38,
      "end": 20.28,
      "speaker": "SPEAKER_00",
      "text": "Câte ore pe zi aproximativ?"
    },
    {
      "start": 20.4,
      "end": 21.92,
      "speaker": "SPEAKER_01",
      "text": "Vreo opt, nouă ore."
    },
    {
      "start": 22.04,
      "end": 26.98,
      "speaker": "SPEAKER_00",
      "text": "Înțeles. Vă doare strict gâtul sau se lasă și pe umăr, pe braț?"
    },
    {
      "start": 27.1,
      "end": 29.0,
      "speaker": "SPEAKER_01",
      "text": "Și pe umăr, pe stânga."
    },
    {
      "start": 29.12,
      "end": 31.78,
      "speaker": "SPEAKER_00",
      "text": "Pe umărul stâng. Braț în jos, amorțeală?"
    },
    {
      "start": 31.9,
      "end": 32.7,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 32.82,
      "end": 37.76,
      "speaker": "SPEAKER_00",
      "text": "Nu. Doare mai tare când vă mișcați gâtul sau și când stați nemișcat?"
    },
    {
      "start": 37.88,
      "end": 39.02,
      "speaker": "SPEAKER_01",
      "text": "Când mă întorc."
    },
    {
      "start": 39.14,
      "end": 43.7,
      "speaker": "SPEAKER_00",
      "text": "Când rotiți, da. În ambele sensuri sau mai mult într-o parte?"
    },
    {
      "start": 43.82,
      "end": 45.34,
      "speaker": "SPEAKER_01",
      "text": "Mai mult spre dreapta."
    },
    {
      "start": 45.46,
      "end": 55.34,
      "speaker": "SPEAKER_00",
      "text": "Spre dreapta doare mai tare. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte rău, unde vă situați?"
    },
    {
      "start": 55.46,
      "end": 56.26,
      "speaker": "SPEAKER_01",
      "text": "Un 5."
    },
    {
      "start": 56.38,
      "end": 60.56,
      "speaker": "SPEAKER_00",
      "text": "Un 5. Dimineața când vă treziți e mai rău sau seara?"
    },
    {
      "start": 60.68,
      "end": 61.48,
      "speaker": "SPEAKER_01",
      "text": "Dimineața."
    },
    {
      "start": 61.6,
      "end": 64.64,
      "speaker": "SPEAKER_00",
      "text": "Dimineața. Înțeles. Alte afecțiuni, tensiune, diabet, osteoporoză, epilepsie?"
    },
    {
      "start": 64.76,
      "end": 65.56,
      "speaker": "SPEAKER_01",
      "text": "Tensiune am."
    },
    {
      "start": 65.68,
      "end": 68.34,
      "speaker": "SPEAKER_00",
      "text": "Aveți tensiune. Luați și tratament pentru asta?"
    },
    {
      "start": 68.46,
      "end": 69.26,
      "speaker": "SPEAKER_01",
      "text": "Da, Enalapril."
    },
    {
      "start": 69.38,
      "end": 70.52,
      "speaker": "SPEAKER_00",
      "text": "Enalapril. Ce doză?"
    },
    {
      "start": 70.64,
      "end": 71.44,
      "speaker": "SPEAKER_01",
      "text": "10 miligrame."
    },
    {
      "start": 71.56,
      "end": 73.84,
      "speaker": "SPEAKER_00",
      "text": "10 miligrame, o dată pe zi?"
    },
    {
      "start": 73.96,
      "end": 74.76,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 74.88,
      "end": 76.02,
      "speaker": "SPEAKER_00",
      "text": "Altceva mai luați?"
    },
    {
      "start": 76.14,
      "end": 76.94,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 77.06,
      "end": 78.2,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale, fracturi?"
    },
    {
      "start": 78.32,
      "end": 79.12,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 79.24,
      "end": 81.52,
      "speaker": "SPEAKER_00",
      "text": "Boli cu transmitere prin sânge, implanturi?"
    },
    {
      "start": 81.64,
      "end": 82.44,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 82.56,
      "end": 86.74,
      "speaker": "SPEAKER_00",
      "text": "Bun. Haideți să vă verific un pic. Stați drept, vă rog."
    },
    {
      "start": 86.86,
      "end": 87.66,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 87.78,
      "end": 91.58,
      "speaker": "SPEAKER_00",
      "text": "O să apăs pe zona cervicală, spuneți-mi dacă doare."
    },
    {
      "start": 91.7,
      "end": 92.84,
      "speaker": "SPEAKER_01",
      "text": "Da, acolo doare."
    },
    {
      "start": 92.96,
      "end": 94.86,
      "speaker": "SPEAKER_00",
      "text": "Aici în C4, C5, da?"
    },
    {
      "start": 94.98,
      "end": 95.78,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 95.9,
      "end": 97.8,
      "speaker": "SPEAKER_00",
      "text": "Apăs pe trapez, pe stânga."
    },
    {
      "start": 97.92,
      "end": 98.72,
      "speaker": "SPEAKER_01",
      "text": "Au, da."
    },
    {
      "start": 98.84,
      "end": 102.64,
      "speaker": "SPEAKER_00",
      "text": "Doare și trapezul stâng. Încercați să rotiți ușor spre dreapta."
    },
    {
      "start": 102.76,
      "end": 103.56,
      "speaker": "SPEAKER_01",
      "text": "Au."
    },
    {
      "start": 103.68,
      "end": 120.78,
      "speaker": "SPEAKER_00",
      "text": "Doare, mobilitate limitată la rotația dreaptă. Bun. Ce pot să vă spun este că avem o contractură musculară în zona cervicală, trapez și ridicătorul scapulei pe stânga, probabil de la postura la birou. Vom lucra să reducem contractura și să redobândim mobilitatea normală a gâtului."
    },
    {
      "start": 120.9,
      "end": 121.7,
      "speaker": "SPEAKER_01",
      "text": "Ok."
    },
    {
      "start": 121.82,
      "end": 123.72,
      "speaker": "SPEAKER_00",
      "text": "Haideți pe masă, vă rog."
    }
  ]
}
