{
  "audio_path": null,
  "language": "ro",
  "model": "claude-opus-4-8",
  "segments": [
    {
      "start": 0.0,
      "end": 1.52,
      "speaker": "SPEAKER_00",
      "text": "Bună ziua, domnule Marin."
    },
    {
      "start": 1.64,
      "end": 2.44,
      "speaker": "SPEAKER_01",
      "text": "Bună ziua."
    },
    {
      "start": 2.56,
      "end": 7.12,
      "speaker": "SPEAKER_00",
      "text": "Spuneți-mi și mie, vă rog, cu ce problemă ne vedem azi."
    },
    {
      "start": 7.24,
      "end": 8.38,
      "speaker": "SPEAKER_01",
      "text": "Mă doare gâtul."
    },
    {
      "start": 8.5,
      "end": 10.4,
      "speaker": "SPEAKER_00",
      "text": "Gâtul, deci zona cervicală, da?"
    },
    {
      "start": 10.52,
      "end": 11.32,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 11.44,
      "end": 13.34,
      "speaker": "SPEAKER_00",
      "text": "De cât timp vă doare?"
    },
    {
      "start": 13.46,
      "end": 14.98,
      "speaker": "SPEAKER_01",
      "text": "De vreo trei zile."
    },
    {
      "start": 15.1,
      "end": 20.04,
      "speaker": "SPEAKER_00",
      "text": "Trei zile. Și ați făcut ceva anume, ați dormit prost, ați ridicat ceva?"
    },
    {
      "start": 20.16,
      "end": 21.3,
      "speaker": "SPEAKER_01",
      "text": "Am dormit prost."
    },
    {
      "start": 21.42,
      "end": 24.84,
      "speaker": "SPEAKER_00",
      "text": "Ați dormit prost. Și de atunci a pornit, da?"
    },
    {
      "start": 24.96,
      "end": 25.76,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 25.88,
      "end": 27.4,
      "speaker": "SPEAKER_00",
      "text": "Ce vârstă aveți dumneavoastră?"
    },
    {
      "start": 27.52,
      "end": 28.32,
      "speaker": "SPEAKER_01",
      "text": "38."
    },
    {
      "start": 28.44,
      "end": 33.38,
      "speaker": "SPEAKER_00",
      "text": "38 de ani. Durerea stă doar în gât sau merge și spre umăr?"
    },
    {
      "start": 33.5,
      "end": 34.3,
      "speaker": "SPEAKER_01",
      "text": "Spre umăr."
    },
    {
      "start": 34.42,
      "end": 35.22,
      "speaker": "SPEAKER_00",
      "text": "Care umăr?"
    },
    {
      "start": 35.34,
      "end": 36.14,
      "speaker": "SPEAKER_01",
      "text": "Drept."
    },
    {
      "start": 36.26,
      "end": 40.06,
      "speaker": "SPEAKER_00",
      "text": "Umărul drept. Și coboară mai jos, pe braț, amorțește ceva?"
    },
    {
      "start": 40.18,
      "end": 40.98,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 41.1,
      "end": 50.98,
      "speaker": "SPEAKER_00",
      "text": "Nu amorțește, bun. Pe o scară de la 0 la 10, unde 0 nu doare deloc și 10 doare foarte tare, cât de tare vă doare?"
    },
    {
      "start": 51.1,
      "end": 51.9,
      "speaker": "SPEAKER_01",
      "text": "Un 6."
    },
    {
      "start": 52.02,
      "end": 56.58,
      "speaker": "SPEAKER_00",
      "text": "Un 6. Doare mai tare când întoarceți capul sau când stați liniștit?"
    },
    {
      "start": 56.7,
      "end": 57.5,
      "speaker": "SPEAKER_01",
      "text": "Când întorc."
    },
    {
      "start": 57.62,
      "end": 62.18,
      "speaker": "SPEAKER_00",
      "text": "Când întoarceți. Haideți să încercăm. Întoarceți capul spre dreapta, vă rog. Doare?"
    },
    {
      "start": 62.3,
      "end": 63.1,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 63.22,
      "end": 64.02,
      "speaker": "SPEAKER_00",
      "text": "Spre stânga?"
    },
    {
      "start": 64.14,
      "end": 64.94,
      "speaker": "SPEAKER_01",
      "text": "Mai puțin."
    },
    {
      "start": 65.06,
      "end": 68.86,
      "speaker": "SPEAKER_00",
      "text": "Mai puțin pe stânga. Și când lăsați bărbia în piept?"
    },
    {
      "start": 68.98,
      "end": 69.78,
      "speaker": "SPEAKER_01",
      "text": "Tot doare."
    },
    {
      "start": 69.9,
      "end": 74.08,
      "speaker": "SPEAKER_00",
      "text": "Tot doare. Vă apăs aici, pe partea dreaptă, pe trapez. Doare?"
    },
    {
      "start": 74.2,
      "end": 75.0,
      "speaker": "SPEAKER_01",
      "text": "Au. Da."
    },
    {
      "start": 75.12,
      "end": 78.54,
      "speaker": "SPEAKER_00",
      "text": "Doare. E foarte încordat aici. Pe stânga la fel?"
    },
    {
      "start": 78.66,
      "end": 79.8,
      "speaker": "SPEAKER_01",
      "text": "Nu așa rău."
    },
    {
      "start": 79.92,
      "end": 85.62,
      "speaker": "SPEAKER_00",
      "text": "Nu așa rău. Bun. Alte afecțiuni mai aveți, cum ar fi tensiune, diabet, cancer, epilepsie?"
    },
    {
      "start": 85.74,
      "end": 86.54,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 86.66,
      "end": 88.18,
      "speaker": "SPEAKER_00",
      "text": "Scolioză, hernie de disc?"
    },
    {
      "start": 88.3,
      "end": 89.1,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 89.22,
      "end": 90.36,
      "speaker": "SPEAKER_00",
      "text": "Intervenții chirurgicale anterioare?"
    },
    {
      "start": 90.48,
      "end": 91.28,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 91.4,
      "end": 92.92,
      "speaker": "SPEAKER_00",
      "text": "Accidente de mașină, fracturi?"
    },
    {
      "start": 93.04,
      "end": 93.84,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 93.96,
      "end": 96.62,
      "speaker": "SPEAKER_00",
      "text": "Luați vreun medicament în momentul de față?"
    },
    {
      "start": 96.74,
      "end": 97.54,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 97.66,
      "end": 99.56,
      "speaker": "SPEAKER_00",
      "text": "Niciun fel de pastilă, da?"
    },
    {
      "start": 99.68,
      "end": 100.48,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 100.6,
      "end": 102.12,
      "speaker": "SPEAKER_00",
      "text": "Alergii la unguente, creme?"
    },
    {
      "start": 102.24,
      "end": 103.04,
      "speaker": "SPEAKER_01",
      "text": "Nu."
    },
    {
      "start": 103.16,
      "end": 119.5,
      "speaker": "SPEAKER_00",
      "text": "Bun. Deci ce avem aici pare a fi o contractură musculară pe zona cervicală, mai ales pe trapezul drept, pornită de la poziția în care ați dormit. Nimic grav. În primă fază vom lucra să relaxăm musculatura și să redăm mobilitatea gâtului, da?"
    },
    {
      "start": 119.62,
      "end": 120.42,
      "speaker": "SPEAKER_01",
      "text": "Da."
    },
    {
      "start": 120.54,
      "end": 125.1,
      "speaker": "SPEAKER_00",
      "text": "Haideți să vă așezați pe masă, vă rog, să trecem la treabă."
    },
    {
      "start": 125.22,
      "end": 126.02,
      "speaker": "SPEAKER_01",
      "text": "Bine."
    }
  ]
}
